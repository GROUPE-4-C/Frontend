@using Microsoft.AspNetCore.Components.Forms
@using AlumniConnect.Front.Models
@inject AlumniConnect.Front.Services.AuthService AuthService
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="create-modal-overlay" id="@ModalId">
    <div class="create-modal">
        <div class="create-modal-header">
            <h3 class="create-modal-title">
                <i class="fas fa-star"></i>
                @Title
            </h3>
            <button class="modal-close-btn" onclick="@($"closeModal('{ModalId}')")">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="create-modal-content">
            <EditForm Model="@localTemoignageModel" OnValidSubmit="@HandleSubmit">
                <DataAnnotationsValidator />

                <div class="modal-form-group">
                    <label class="modal-form-label">
                        <i class="fas fa-star"></i>
                        Votre témoignage *
                    </label>
                    <InputTextArea @bind-Value="localTemoignageModel.Contenu"
                                   class="modal-form-textarea"
                                   rows="8"
                                   style="min-height: 180px;"
                                   placeholder="Racontez votre parcours, vos expériences, vos conseils... Soyez authentique et inspirant !" />
                    <ValidationMessage For="@(() => localTemoignageModel.Contenu)" />
                </div>

                <div class="modal-form-actions">
                    <button type="submit" class="modal-btn-primary" disabled="@IsSubmitting">
                        @if (IsSubmitting)
                        {
                            <i class="fas fa-spinner fa-spin"></i>
                            <span>Publication...</span>
                        }
                        else
                        {
                            <i class="fas fa-star"></i>
                            <span>Publier le témoignage</span>
                        }
                    </button>
                    <button type="button" class="modal-btn-secondary" onclick="@($"closeModal('{ModalId}')")">
                        <i class="fas fa-times"></i>
                        Annuler
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [Parameter] public string ModalId { get; set; } = "createTemoignageModal";
    [Parameter] public string Title { get; set; } = "Rédiger un témoignage";
    [Parameter] public TemoignageModel TemoignageModel { get; set; } = new();
    [Parameter] public EventCallback<TemoignageModel> OnSubmit { get; set; }
    [Parameter] public bool IsSubmitting { get; set; } = false;

    private TemoignageModel localTemoignageModel = new();
    private bool hasSubmitted = false;

    protected override void OnInitialized()
    {
        localTemoignageModel = new TemoignageModel();
        hasSubmitted = false;
    }

    private async Task HandleSubmit()
    {
        if (hasSubmitted || string.IsNullOrWhiteSpace(localTemoignageModel.Contenu)) return;

        try
        {
            hasSubmitted = true;
            var token = await AuthService.GetTokenAsync();
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

                var response = await Http.PostAsJsonAsync("http://localhost:5175/api/temoignages", new
                {
                    contenu = localTemoignageModel.Contenu
                });

                if (response.IsSuccessStatusCode)
                {
                    var createdTemoignage = await response.Content.ReadFromJsonAsync<TemoignageModel>();

                    // Fermer le modal avant de notifier le parent
                    await JSRuntime.InvokeVoidAsync("closeModal", ModalId);

                    // Notifier le parent avec le témoignage créé
                    if (OnSubmit.HasDelegate && createdTemoignage != null)
                    {
                        await OnSubmit.InvokeAsync(createdTemoignage);
                    }

                    // Reset du formulaire
                    localTemoignageModel = new();
                    StateHasChanged();
                }
                else
                {
                    hasSubmitted = false; // Réinitialise le flag en cas d'erreur
                    var error = await response.Content.ReadAsStringAsync();
                    Console.WriteLine($"Erreur lors de la création du témoignage: {error}");
                }
            }
            else
            {
                hasSubmitted = false;
                Console.WriteLine("Token non trouvé - utilisateur non connecté");
            }
        }
        catch (Exception ex)
        {
            hasSubmitted = false;
            Console.WriteLine($"Erreur lors de la création du témoignage: {ex.Message}");
        }
    }

    public void Dispose()
    {
        localTemoignageModel = new();
        hasSubmitted = false;
    }
}
