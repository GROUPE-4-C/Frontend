@using Microsoft.AspNetCore.Components.Forms
@using AlumniConnect.Front.Models
@using AlumniConnect.Front.Utils
@using System.Net.Http.Headers
@using System.Text.Json
@inject HttpClient Http
@inject AlumniConnect.Front.Services.AuthService AuthService
@inject IJSRuntime JSRuntime

<div class="create-modal-overlay" id="@ModalId">
    <div class="create-modal">
        <div class="create-modal-header">
            <h3 class="create-modal-title">
                <i class="fas fa-star"></i>
                @Title
            </h3>
            <button class="modal-close-btn" onclick="@($"closeModal('{ModalId}')")">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="create-modal-content">
            <!-- Instructions -->
            <div style="background: linear-gradient(135deg, rgba(159, 122, 234, 0.1), rgba(102, 126, 234, 0.1)); padding: 20px; border-radius: 12px; border-left: 4px solid #9f7aea; margin-bottom: 24px;">
                <h4 style="color: #2d3748; margin-bottom: 12px;">💡 Quelques conseils pour un témoignage inspirant :</h4>
                <ul style="color: #4a5568; margin: 0; padding-left: 20px; font-size: 13px;">
                    <li>Partagez votre parcours professionnel depuis l'obtention du diplôme</li>
                    <li>Mentionnez les défis rencontrés et comment vous les avez surmontés</li>
                    <li>Donnez des conseils aux nouveaux diplômés</li>
                    <li>N'hésitez pas à mentionner comment le réseau alumni vous a aidé</li>
                </ul>
            </div>

            <EditForm Model="@localTemoignageModel" OnValidSubmit="@HandleSubmit">
                <DataAnnotationsValidator />

                <div class="modal-form-group">
                    <label class="modal-form-label">
                        <i class="fas fa-star"></i>
                        Votre témoignage *
                    </label>
                    <InputTextArea @bind-Value="localTemoignageModel.Contenu"
                                   class="modal-form-textarea"
                                   rows="8"
                                   style="min-height: 180px;"
                                   placeholder="Racontez votre parcours, vos expériences, vos conseils... Soyez authentique et inspirant !" />
                    <ValidationMessage For="@(() => localTemoignageModel.Contenu)" />
                </div>

                <div class="modal-form-actions">
                    <button type="submit" class="modal-btn-primary" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <i class="fas fa-spinner fa-spin"></i>
                            <span>Publication...</span>
                        }
                        else
                        {
                            <i class="fas fa-star"></i>
                            <span>@SubmitText</span>
                        }
                    </button>
                    <button type="button" class="modal-btn-secondary" onclick="@($"closeModal('{ModalId}')")">
                        <i class="fas fa-times"></i>
                        Annuler
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [Parameter] public string ModalId { get; set; } = "createTemoignageModal";
    [Parameter] public string Title { get; set; } = "Rédiger un témoignage";
    [Parameter] public string SubmitText { get; set; } = "Publier le témoignage";
    [Parameter] public TemoignageModel TemoignageModel { get; set; } = new();
    [Parameter] public EventCallback<TemoignageModel> OnSubmit { get; set; }
    [Parameter] public bool IsSubmitting { get; set; }

    private TemoignageModel localTemoignageModel = new();
    private bool isSubmitting = false;
    private bool hasSubmitted = false;

    protected override void OnInitialized()
    {
        // Si c'est une modification, on copie les données du modèle existant
        if (!string.IsNullOrEmpty(TemoignageModel.Id))
        {
            localTemoignageModel = new TemoignageModel
            {
                Id = TemoignageModel.Id,
                Contenu = TemoignageModel.Contenu,
                MotsCles = TemoignageModel.MotsCles,
                UserId = TemoignageModel.UserId
            };
        }
        else
        {
            localTemoignageModel = new TemoignageModel();
        }
        hasSubmitted = false;
    }

    private async Task HandleSubmit()
    {
        if (hasSubmitted || isSubmitting || string.IsNullOrWhiteSpace(localTemoignageModel.Contenu))
            return;

        isSubmitting = true;
        StateHasChanged();

        try
        {
            var token = await AuthService.GetTokenAsync();
            if (string.IsNullOrEmpty(token))
            {
                throw new Exception("Vous devez être connecté pour publier un témoignage.");
            }

            // Configurer le header d'autorisation
            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            // Préparer les données pour l'API
            var temoignageData = new
            {
                contenu = localTemoignageModel.Contenu,
                motsCles = localTemoignageModel.MotsCles
            };

            // Faire l'appel API
            HttpResponseMessage response;
            if (string.IsNullOrEmpty(localTemoignageModel.Id))
            {
                response = await Http.PostAsJsonAsync("http://localhost:5175/api/temoignages", temoignageData);
            }
            else
            {
                response = await Http.PutAsJsonAsync($"http://localhost:5175/api/temoignages/{localTemoignageModel.Id}", temoignageData);
            }

            if (response.IsSuccessStatusCode)
            {
                var createdTemoignage = await response.Content.ReadFromJsonAsync<TemoignageModel>();

                // Fermer le modal
                await JSRuntime.InvokeVoidAsync("closeModal", ModalId);

                // Notifier le parent avec le témoignage créé
                if (OnSubmit.HasDelegate && createdTemoignage != null)
                {
                    await OnSubmit.InvokeAsync(createdTemoignage);
                }

                // Reset du formulaire
                localTemoignageModel = new();
                hasSubmitted = true;
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                throw new Exception($"Erreur lors de la création du témoignage: {errorContent}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur: {ex.Message}");
            await JSRuntime.InvokeVoidAsync("alert", $"Erreur: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }
}
