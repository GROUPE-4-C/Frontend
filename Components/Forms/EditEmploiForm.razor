@using Microsoft.AspNetCore.Components.Forms
@using AlumniConnect.Front.Models
@inject AlumniConnect.Front.Services.AuthService AuthService
@inject HttpClient Http
@inject IJSRuntime JSRuntime

<div class="create-modal-overlay" id="@ModalId">
    <div class="create-modal">
        <div class="create-modal-header">
            <h3 class="create-modal-title">
                <i class="fas fa-briefcase"></i>
                Modifier l'offre d'emploi
            </h3>
            <button class="modal-close-btn" onclick="@($"closeModal('{ModalId}')")">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="create-modal-content">
            <EditForm Model="@emploiModel" OnValidSubmit="@HandleSubmit" id="editEmploiForm">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="modal-form-group">
                    <label class="modal-form-label">
                        <i class="fas fa-briefcase"></i>
                        Titre du poste *
                    </label>
                    <InputText @bind-Value="emploiModel.Titre" class="modal-form-input" placeholder="Ex: Développeur Full Stack Senior" />
                    <ValidationMessage For="@(() => emploiModel.Titre)" />
                </div>

                <div class="modal-form-group">
                    <label class="modal-form-label">
                        <i class="fas fa-building"></i>
                        Entreprise *
                    </label>
                    <InputText @bind-Value="emploiModel.Entreprise" class="modal-form-input" placeholder="Ex: TechCorp Solutions" />
                    <ValidationMessage For="@(() => emploiModel.Entreprise)" />
                </div>

                <div class="modal-form-group">
                    <label class="modal-form-label">
                        <i class="fas fa-map-marker-alt"></i>
                        Localisation *
                    </label>
                    <InputText @bind-Value="emploiModel.Localisation" class="modal-form-input" placeholder="Ex: Paris, France" />
                    <ValidationMessage For="@(() => emploiModel.Localisation)" />
                </div>

                <div class="modal-form-grid">
                    <div class="modal-form-group">
                        <label class="modal-form-label">
                            <i class="fas fa-calendar"></i>
                            Date de début
                        </label>
                        <InputDate @bind-Value="emploiModel.DateDebut" class="modal-form-input" />
                    </div>
                    <div class="modal-form-group">
                        <label class="modal-form-label">
                            <i class="fas fa-calendar-check"></i>
                            Date de fin (optionnel)
                        </label>
                        <InputDate @bind-Value="emploiModel.DateFin" class="modal-form-input" />
                    </div>
                </div>

                <div class="modal-form-group">
                    <label class="modal-form-label">
                        <i class="fas fa-align-left"></i>
                        Description du poste *
                    </label>
                    <InputTextArea @bind-Value="emploiModel.Description" class="modal-form-textarea" placeholder="Décrivez le poste, les responsabilités, les compétences requises..." />
                    <ValidationMessage For="@(() => emploiModel.Description)" />
                </div>

                <div class="modal-form-group">
                    <label class="modal-form-label">
                        <i class="fas fa-image"></i>
                        Image de l'offre (optionnel)
                    </label>
                    <div class="modal-form-file-container">
                        <div class="modal-form-file-input">
                            <InputFile OnChange="@HandleImageSelection" accept="image/*" />
                            <div class="modal-form-file-label">
                                <div class="modal-form-file-icon">
                                    <i class="fas fa-cloud-upload-alt"></i>
                                </div>
                                <div class="modal-form-file-text">
                                    @if (!string.IsNullOrEmpty(selectedImageName))
                                    {
                                        <span>📁 @selectedImageName</span>
                                    }
                                    else if (!string.IsNullOrEmpty(emploiModel.ImageUrl))
                                    {
                                        <span>Image existante</span>
                                    }
                                    else
                                    {
                                        <span>Cliquez pour sélectionner une image</span>
                                    }
                                </div>
                                <div class="modal-form-file-hint">PNG, JPG, GIF jusqu'à 5MB</div>
                            </div>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(emploiModel.ImageUrl) && string.IsNullOrEmpty(selectedImageName))
                    {
                        <div style="margin-top:10px;">
                            <img src="@emploiModel.ImageUrl"
                                 alt="Image actuelle"
                                 style="max-width: 100%; max-height: 120px; border-radius: 8px; border: 1px solid #e2e8f0;" />
                        </div>
                    }
                </div>

                <div class="modal-form-actions">
                    <button type="submit" class="modal-btn-primary" style="background: linear-gradient(135deg, #3182ce, #2c5282);" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <i class="fas fa-spinner fa-spin"></i>
                            <span>Enregistrement...</span>
                        }
                        else
                        {
                            <i class="fas fa-save"></i>
                            <span>Enregistrer les modifications</span>
                        }
                    </button>
                    <button type="button" class="modal-btn-secondary" onclick="@($"closeModal('{ModalId}')")">
                        <i class="fas fa-times"></i>
                        Annuler
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [Parameter] public string ModalId { get; set; } = "editEmploiModal";
    [Parameter] public EmploiModel EmploiModel { get; set; } = new();
    [Parameter] public EventCallback<EmploiModel> OnSubmit { get; set; }
    [Parameter] public bool IsSubmitting { get; set; } = false;

    private EmploiModel emploiModel = new();
    private bool isSubmitting = false;
    private string selectedImageName = string.Empty;
    private string? imagePreview;

    protected override void OnParametersSet()
    {
        // Copier les données de l'offre à modifier
        emploiModel = new EmploiModel
        {
            Id = EmploiModel.Id,
            Titre = EmploiModel.Titre,
            Entreprise = EmploiModel.Entreprise,
            Localisation = EmploiModel.Localisation,
            DateDebut = EmploiModel.DateDebut,
            DateFin = EmploiModel.DateFin,
            Description = EmploiModel.Description,
            ImageUrl = EmploiModel.ImageUrl,
            ImageBase64 = EmploiModel.ImageBase64,
            UserId = EmploiModel.UserId,
            CreatorName = EmploiModel.CreatorName,
            CreatorEmail = EmploiModel.CreatorEmail
        };
        selectedImageName = string.Empty;
        imagePreview = null;
    }

    private async Task HandleSubmit()
    {
        try
        {
            // Validation basique
           if (string.IsNullOrWhiteSpace(emploiModel.Titre) || string.IsNullOrWhiteSpace(emploiModel.Description))
           {
               await JSRuntime.InvokeVoidAsync("alert", "Veuillez remplir tous les champs obligatoires");
               return;
           }

           // Correction image : si ImageBase64 existe, on efface ImageUrl pour éviter la validation [Url]
           if (!string.IsNullOrEmpty(emploiModel.ImageBase64))
           {
               emploiModel.ImageUrl = null;
           }

           isSubmitting = true;
           StateHasChanged();

           var token = await AuthService.GetTokenAsync();
           if (string.IsNullOrEmpty(token))
           {
               throw new Exception("Vous devez être connecté pour modifier une offre d'emploi.");
           }

           Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

           // Utiliser PUT pour mettre à jour l'offre d'emploi
           var response = await Http.PutAsJsonAsync($"http://localhost:5175/api/emplois/{emploiModel.Id}", emploiModel);

           if (response.IsSuccessStatusCode)
           {
               await JSRuntime.InvokeVoidAsync("closeModal", ModalId);

               if (OnSubmit.HasDelegate)
               {
                   await OnSubmit.InvokeAsync(emploiModel);
               }

               await JSRuntime.InvokeVoidAsync("alert", "Offre d'emploi modifiée avec succès !");
               await JSRuntime.InvokeVoidAsync("location.reload");
           }
           else
           {
               var error = await response.Content.ReadAsStringAsync();
               throw new Exception($"Erreur lors de la modification: {error}");
           }
       }
       catch (Exception ex)
       {
           await JSRuntime.InvokeVoidAsync("alert", $"Erreur: {ex.Message}");
           Console.WriteLine($"Erreur lors de la modification: {ex.Message}");
       }
       finally
       {
           isSubmitting = false;
           StateHasChanged();
       }
   }

    private async Task HandleImageSelection(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            selectedImageName = file.Name;
            using var stream = file.OpenReadStream(5 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var bytes = memoryStream.ToArray();
            imagePreview = $"data:{file.ContentType};base64,{Convert.ToBase64String(bytes)}";
            emploiModel.ImageBase64 = imagePreview;
            // On efface l'URL si on upload une nouvelle image
            emploiModel.ImageUrl = null;
            StateHasChanged();
        }
    }
}
