@* Composant navbar partagé pour uniformiser l'interface *@
@using AlumniConnect.Front.Models
@inject AlumniConnect.Front.Services.AuthService AuthService
@inject NavigationManager NavigationManager

<!-- Header moderne -->
<header class="modern-header">
    <div class="header-container">
        <!-- Logo Section -->
        <div class="logo-section">
            <a href="/dashboard" class="logo">
                <div class="logo-icon">
                    <i class="fas fa-graduation-cap"></i>
                </div>
                <span class="logo-text">AlumniConnect</span>
            </a>
        </div>

        <!-- Search Section -->
        <div class="search-section">
            <div class="search-container">
                <i class="fas fa-search search-icon"></i>
                <input type="text"
                       class="search-input"
                       placeholder="@GetSearchPlaceholder()"
                       @onclick="@(() => { if(RequireLogin) NavigationManager.NavigateTo("/login"); })">
                <div class="search-suggestions" id="searchSuggestions">
                    <!-- Suggestions dynamiques -->
                </div>
            </div>
        </div>

        <!-- Navigation Menu -->
        <nav class="nav-section">
            <div class="nav-items">
                <a href="/dashboard" class="nav-link @(ActivePage == "dashboard" ? "active" : "")">
                    <div class="nav-icon">
                        <i class="fas fa-home"></i>
                    </div>
                    <span class="nav-label">Accueil</span>
                </a>

            <a href="/alumni" class="nav-link @(ActivePage == "reseau" ? "active" : "")">
    <div class="nav-icon">
        <i class="fas fa-users"></i>
    </div>
    <span class="nav-label">Réseau</span>
</a>



                <a href="/emplois" class="nav-link @(ActivePage == "emplois" ? "active" : "")">
                    <div class="nav-icon">
                        <i class="fas fa-briefcase"></i>
                    </div>
                    <span class="nav-label">Emplois</span>
                </a>

                <a href="/temoignages" class="nav-link @(ActivePage == "temoignages" ? "active" : "")">
                    <div class="nav-icon">
                        <i class="fas fa-star"></i>
                    </div>
                    <span class="nav-label">Témoignages</span>
                </a>

                <a href="/events" class="nav-link @(ActivePage == "events" ? "active" : "")">
                    <div class="nav-icon">
                        <i class="fas fa-calendar-alt"></i>
                    </div>
                    <span class="nav-label">Événements</span>
                </a>

                <div class="nav-link @(ActivePage == "messages" ? "active" : "")" @onclick="@(() => NavigationManager.NavigateTo("/login"))">
                    <div class="nav-icon">
                        <i class="fas fa-comment-dots"></i>
                        <span class="nav-badge notification">3</span>
                    </div>
                    <span class="nav-label">Messages</span>
                </div>

                <div class="nav-link @(ActivePage == "notifications" ? "active" : "")" @onclick="@(() => NavigationManager.NavigateTo("/login"))">
                    <div class="nav-icon">
                        <i class="fas fa-bell"></i>
                        <span class="nav-badge notification">5</span>
                    </div>
                    <span class="nav-label">Notifications</span>
                </div>
            </div>
        </nav>

        <!-- User Section -->
        <div class="user-section">
            <div class="user-menu">
                @if (currentUser != null)
                {
                    <a href="/profile" class="profile-link @(ActivePage == "profile" ? "active" : "")">
                        <div class="profile-avatar">
                            @if (!string.IsNullOrEmpty(currentUser.PhotoUrl))
                            {
                                <img src="@GetFullPhotoUrl(currentUser.PhotoUrl)" alt="Avatar" class="avatar-img" />
                            }
                            else
                            {
                                <img src="images/default-avatar.png" alt="Avatar" class="avatar-img" />
                            }
                        </div>
                        <span class="profile-name">@currentUser.FullName</span>
                    </a>

                    <button class="login-button" @onclick="Logout">
                        <i class="fas fa-sign-out-alt"></i>
                        <span>Déconnexion</span>
                    </button>
                }
                else
                {
                    <a href="/login" class="login-button">
                        <i class="fas fa-sign-in-alt"></i>
                        <span>Connexion</span>
                    </a>
                }
            </div>
        </div>

        <!-- Mobile Menu Toggle -->
        <button class="mobile-menu-toggle" onclick="toggleMobileMenu()">
            <span class="hamburger"></span>
            <span class="hamburger"></span>
            <span class="hamburger"></span>
        </button>
    </div>

    <!-- Mobile Navigation -->
    <div class="mobile-nav" id="mobileNav">
        <div class="mobile-nav-content">
            <div class="mobile-search">
                <i class="fas fa-search"></i>
                <input type="text" placeholder="@GetSearchPlaceholder()">
            </div>

            <div class="mobile-nav-items">
                <a href="/dashboard" class="mobile-nav-item @(ActivePage == "dashboard" ? "active" : "")">
                    <i class="fas fa-home"></i>
                    <span>Accueil</span>
                </a>
                <div class="mobile-nav-item" onclick="requireLogin()">
                    <i class="fas fa-users"></i>
                    <span>Réseau</span>
                    <span class="mobile-badge">12</span>
                </div>
                <a href="/emplois" class="mobile-nav-item @(ActivePage == "emplois" ? "active" : "")">
                    <i class="fas fa-briefcase"></i>
                    <span>Emplois</span>
                </a>
                <a href="/temoignages" class="mobile-nav-item @(ActivePage == "temoignages" ? "active" : "")">
                    <i class="fas fa-star"></i>
                    <span>Témoignages</span>
                </a>
                <a href="/events" class="mobile-nav-item @(ActivePage == "events" ? "active" : "")">
                    <i class="fas fa-calendar-alt"></i>
                    <span>Événements</span>
                </a>
                <div class="mobile-nav-item" onclick="requireLogin()">
                    <i class="fas fa-comment-dots"></i>
                    <span>Messages</span>
                    <span class="mobile-badge notification">3</span>
                </div>
                <div class="mobile-nav-item" onclick="requireLogin()">
                    <i class="fas fa-bell"></i>
                    <span>Notifications</span>
                    <span class="mobile-badge notification">5</span>
                </div>
                <a href="/profile" class="mobile-nav-item @(ActivePage == "profile" ? "active" : "")">
                    <i class="fas fa-user-circle"></i>
                    <span>Profil</span>
                </a>
            </div>

            <div class="mobile-login">
                <a href="/login" class="mobile-login-btn">
                    <i class="fas fa-sign-in-alt"></i>
                    Se connecter
                </a>
            </div>
        </div>
    </div>
</header>



@code {
    [Parameter] public string ActivePage { get; set; } = "";
    [Parameter] public bool RequireLogin { get; set; } = true;
    private UserInfo? currentUser;

    private string GetFullPhotoUrl(string? photoUrl)
    {
        if (string.IsNullOrWhiteSpace(photoUrl))
            return "images/default-avatar.png";

        if (photoUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase))
            return photoUrl;

        return $"http://localhost:5175{photoUrl}";
    }

    protected override async Task OnInitializedAsync()
    {
        currentUser = await AuthService.GetCurrentUserAsync();
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/", true);
    }

    private string GetSearchPlaceholder()
    {
        return ActivePage switch
        {
            "emplois" => "Rechercher des emplois, entreprises...",
            "events" => "Rechercher des événements...",
            "temoignages" => "Rechercher des témoignages...",
            _ => "Rechercher des alumni, entreprises, postes..."
        };
    }
}
