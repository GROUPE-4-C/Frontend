@using AlumniConnect.Front.Models 
@using Microsoft.AspNetCore.Components.Forms 
@using Microsoft.AspNetCore.Components.Web;
@using Microsoft.AspNetCore.Components.WebAssembly.Hosting;

<div class="card">
    <div class="card-body">
        <h5 class="card-title">@Promotion.Nom</h5>
        <p class="card-text">ID: @Promotion.Id</p>
        
        <button class="btn btn-primary btn-sm me-2" @onclick="() => OnEdit.InvokeAsync(Promotion)">
            ✏️ Éditer
        </button>
        <button class="btn btn-danger btn-sm" @onclick="() => OnDelete.InvokeAsync(Promotion.Id)">
            🗑️ Supprimer
        </button>
    </div>
</div>

@code {
    [Parameter]
    public Promotion Promotion { get; set; } = new Promotion();

    [Parameter]
    public EventCallback<Promotion> OnEdit { get; set; }

    [Parameter]
    public EventCallback<int> OnDelete { get; set; }
}