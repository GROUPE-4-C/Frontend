@page "/temoignages"
@layout MainLayout
@using AlumniConnect.Front.Components.Forms
@using AlumniConnect.Front.Models
@using AlumniConnect.Front.Utils
@using AlumniConnect.Front.Services
@inject HttpClient Http
@inject AuthService AuthService
@inject IJSRuntime JSRuntime


<link href="css/shared-navbar.css" rel="stylesheet" />
<link href="css/body-layout.css" rel="stylesheet" />
<link href="css/dashboard.css" rel="stylesheet" />
<link href="css/modal-forms.css" rel="stylesheet" />
<link href="css/temoignages.css" rel="stylesheet" />

<script src="js/modals.js"></script>

<!-- Composant Temoignage Form -->
<TemoignageForm ModalId="createTemoignageModal"
                TemoignageModel="@temoignageModel"
                OnSubmit="@HandleTemoignageSubmit"
                IsSubmitting="@isSubmitting" />

<!-- Navbar partagée -->
<SharedNavbar ActivePage="temoignages" RequireLogin="false" />

<!-- Main Container -->
<div class="main-container temoignages-layout">
    <!-- Sidebar Left -->
    <aside class="welcome-card static-sidebar">
        <h3>⭐ Témoignages Alumni</h3>
        <p>Partagez votre expérience et découvrez les parcours inspirants de notre communauté d'alumni.</p>
        <button class="login-cta" onclick="openModal('createTemoignageModal')">
            <i class="fas fa-plus"></i>
            Rédiger un témoignage
        </button>
    </aside>

    <!-- Main Feed -->
    <main class="main-feed scrollable-feed">
        <!-- Filter Bar -->
        <div class="post-composer">
            <div class="composer-input">
                <div class="composer-avatar">⭐</div>
                <input type="text" placeholder="Filtrer par nom, promotion, mot-clé...">
            </div>
            <div class="composer-actions">
                <div class="composer-action">
                    <i class="fas fa-graduation-cap"></i>
                    Par promotion
                </div>
                <div class="composer-action">
                    <i class="fas fa-clock"></i>
                    Plus récents
                </div>
                <div class="composer-action">
                    <i class="fas fa-heart"></i>
                    Plus appréciés
                </div>
                <div class="composer-action">
                    <i class="fas fa-tags"></i>
                    Catégories
                </div>
            </div>
        </div>

        <!-- Testimonials Feed identique à Dashboard -->
        @if (temoignages == null)
        {
            <div class="loading-state">
                <div class="loading-spinner"></div>
                <p>Chargement des témoignages...</p>
            </div>
        }
        else if (!temoignages.Any())
        {
            <div class="empty-state">
                <i class="fas fa-star"></i>
                <h3>Aucun témoignage</h3>
                <p>Les témoignages apparaîtront ici.</p>
            </div>
        }
        else
        {
            @foreach (var temoignage in temoignages.OrderByDescending(t => t.Date))
            {
                <article class="post testimonial-post">
                    <div class="post-header">
                        <div class="post-avatar" style="background: linear-gradient(135deg, #9f7aea, #805ad5);">
                            @if (!string.IsNullOrEmpty(temoignage.PhotoUrl))
                            {
                                <img src="@(PhotoUrlHelper.GetFullPhotoUrl(temoignage.PhotoUrl))" alt="Avatar" class="avatar-img" />
                            }
                            else
                            {
                                <span>@(string.IsNullOrEmpty(temoignage.FullName) ? "??" : (temoignage.FullName.Length >= 2 ? temoignage.FullName.Substring(0, 2) : temoignage.FullName))</span>
                            }
                        </div>
                        <div class="post-author-info">
                            <div class="post-author-name">@temoignage.FullName</div>
                            <div class="post-author-title">@temoignage.Profession • @temoignage.Promotion</div>
                            <div class="post-time">
                                <span>@FormatDate(temoignage.Date)</span>
                                <i class="fas fa-globe-americas"></i>
                            </div>
                        </div>
                    </div>

                    <div class="post-content">
                        <div class="testimonial-badge">
                            <i class="fas fa-star"></i>
                            Témoignage
                        </div>

                        @((MarkupString)FormatContent(temoignage.Contenu))

                        @if (!string.IsNullOrEmpty(temoignage.MotsCles))
                        {
                            <br><br>
                            <div class="tags">
                                <span class="tag">#Témoignage</span>
                                @foreach (var tag in temoignage.MotsCles.Split(','))
                                {
                                    <span class="tag">#@tag.Trim()</span>
                                }
                            </div>
                        }
                    </div>
                </article>
            }
        }
    </main>
</div>

@code {
    private TemoignageModel temoignageModel = new();
    private bool isSubmitting = false;
    private List<TemoignageModel>? temoignages;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            temoignages = await Http.GetFromJsonAsync<List<TemoignageModel>>("/api/temoignages");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors du chargement des témoignages: {ex.Message}");
            temoignages = new List<TemoignageModel>();
        }
    }

private async Task HandleTemoignageSubmit(TemoignageModel model)
{
    if (model != null && !string.IsNullOrWhiteSpace(model.Contenu))
    {
        try
        {
            // Ajouter le nouveau témoignage à la liste
            if (temoignages == null)
            {
                temoignages = new List<TemoignageModel>();
            }
            temoignages.Insert(0, model);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors de l'ajout du témoignage: {ex.Message}");
        }
    }
}




    private string FormatDate(DateTime date)
    {
        var difference = DateTime.Now - date;

        if (difference.TotalMinutes < 60)
            return $"{(int)difference.TotalMinutes}min";
        if (difference.TotalHours < 24)
            return $"{(int)difference.TotalHours}h";
        if (difference.TotalDays < 30)
            return $"{(int)difference.TotalDays}j";
        return date.ToString("dd MMM yyyy");
    }

    private string FormatContent(string content)
    {
        if (string.IsNullOrEmpty(content)) return "";
        return content.Replace("\n", "<br>");
    }
}
