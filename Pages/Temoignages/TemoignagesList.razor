@page "/temoignages"
@layout MainLayout
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@using Microsoft.Extensions.Logging
@using System.Net.Http.Json
@using AlumniConnect.Front.Components.Forms
@using AlumniConnect.Front.Models
@using AlumniConnect.Front.Utils
@using AlumniConnect.Front.Services

@inject HttpClient Http
@inject AuthService AuthService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject ILogger<TemoignagesList> Logger
@implements IDisposable

<link href="css/shared-navbar.css" rel="stylesheet" />
<link href="css/body-layout.css" rel="stylesheet" />
<link href="css/dashboard.css" rel="stylesheet" />
<link href="css/modal-forms.css" rel="stylesheet" />
<link href="css/temoignages.css" rel="stylesheet" />

<script src="js/modals.js"></script>
<script src="js/temoignages.js"></script>

<!-- Composant Temoignage Form -->
<TemoignageForm ModalId="createTemoignageModal"
                TemoignageModel="@temoignageModel"
                OnSubmit="@HandleTemoignageSubmit"
                IsSubmitting="@isSubmitting" />

<!-- Composant Edit Temoignage Form -->
<EditTemoignageForm ModalId="editTemoignageModal"
                    TemoignageModel="@editingTemoignage"
                    OnSubmit="@HandleTemoignageEdit"
                    IsSubmitting="@isSubmitting" />

<!-- Navbar partagée -->
<SharedNavbar ActivePage="temoignages" RequireLogin="false" />

<!-- Main Container -->
<div class="main-container temoignages-layout">
    <!-- Sidebar Left -->
    <aside class="welcome-card static-sidebar">
        <h3>⭐ Témoignages Alumni</h3>
        <p>Partagez votre expérience et découvrez les parcours inspirants de notre communauté d'alumni.</p>
        <button class="login-cta" onclick="openModal('createTemoignageModal')">
            <i class="fas fa-plus"></i>
            Rédiger un témoignage
        </button>
    </aside>

    <!-- Main Feed -->
    <main class="main-feed scrollable-feed">
        <!-- Filter Bar -->
        <div class="post-composer">
            <div class="composer-input">
                <div class="composer-avatar">⭐</div>
                <input type="text" placeholder="Filtrer par nom, promotion, mot-clé...">
            </div>
            <div class="composer-actions">
                <div class="composer-action">
                    <i class="fas fa-graduation-cap"></i>
                    Par promotion
                </div>
                <div class="composer-action">
                    <i class="fas fa-clock"></i>
                    Plus récents
                </div>
                <div class="composer-action">
                    <i class="fas fa-heart"></i>
                    Plus appréciés
                </div>
                <div class="composer-action">
                    <i class="fas fa-tags"></i>
                    Catégories
                </div>
            </div>
        </div>

        <!-- Testimonials Feed -->
        @if (temoignages == null)
        {
            <div class="loading-state">
                <div class="loading-spinner"></div>
                <p>Chargement des témoignages...</p>
            </div>
        }
        else if (!temoignages.Any())
        {
            <div class="empty-state">
                <i class="fas fa-star"></i>
                <h3>Aucun témoignage</h3>
                <p>Les témoignages apparaîtront ici.</p>
            </div>
        }
        else
        {
            @foreach (var temoignage in temoignages.OrderByDescending(t => t.Date))
            {
                <article class="post testimonial-post">
                    <div class="post-header">
                        <div class="post-avatar" style="background: linear-gradient(135deg, #9f7aea, #805ad5);">
                            @if (!string.IsNullOrEmpty(temoignage.PhotoUrl))
                            {
                                <img src="@(PhotoUrlHelper.GetFullPhotoUrl(temoignage.PhotoUrl))" alt="Avatar" class="avatar-img" />
                            }
                            else
                            {
                                <span>@(string.IsNullOrEmpty(temoignage.FullName) ? "??" : (temoignage.FullName.Length >= 2 ? temoignage.FullName.Substring(0, 2) : temoignage.FullName))</span>
                            }
                        </div>
                        <div class="post-author-info">
                            <div class="post-author-name">@temoignage.FullName</div>
                            <div class="post-author-title">@temoignage.Profession • @temoignage.Promotion</div>
                            <div class="post-time">
                                <span>@FormatDate(temoignage.Date)</span>
                                <i class="fas fa-globe-americas"></i>
                            </div>
                        </div>
                        @if (currentUser != null && currentUser.Id == temoignage.UserId)
                        {
                            <div class="post-actions">
                                <div class="dropdown">
                                    <button type="button"
                                            class="btn-icon"
                                            @onclick="@(() => ShowOptionsMenu(temoignage.Id))"
                                            title="Options">
                                        <i class="fas fa-ellipsis-v"></i>
                                    </button>
                                    @if (activeDropdownId == temoignage.Id)
                                    {
                                        <div class="dropdown-menu show" @onclick:stopPropagation data-id="@temoignage.Id">
                                            <button type="button"
                                                    class="dropdown-item"
                                                    @onclick="@(() => ShowEditModal(temoignage))">
                                                <i class="fas fa-edit"></i> Modifier
                                            </button>
                                            <button type="button"
                                                    class="dropdown-item delete"
                                                    @onclick="@(async () => await DeleteTemoignage(temoignage.Id))"
                                                    @onclick:stopPropagation="true">
                                                <i class="fas fa-trash"></i> Supprimer
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <div class="post-content">
                        <div class="testimonial-badge">
                            <i class="fas fa-star"></i>
                            Témoignage
                        </div>

                        @((MarkupString)FormatContent(temoignage.Contenu))

                        @if (!string.IsNullOrEmpty(temoignage.MotsCles))
                        {
                            <br><br>
                            <div class="tags">
                                <span class="tag">#Témoignage</span>
                                @foreach (var tag in temoignage.MotsCles.Split(','))
                                {
                                    <span class="tag">#@tag.Trim()</span>
                                }
                            </div>
                        }
                    </div>
                </article>
            }
        }
    </main>
</div>

@code {
    private TemoignageModel temoignageModel = new();
    private TemoignageModel editingTemoignage = new();
    private bool isSubmitting = false;
    private List<TemoignageModel>? temoignages;
    private string? activeDropdownId;
    private UserInfo? currentUser;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            currentUser = await AuthService.GetCurrentUserAsync();
            Logger.LogInformation($"CurrentUser loaded: {currentUser?.Id}");

            temoignages = await Http.GetFromJsonAsync<List<TemoignageModel>>("http://localhost:5175/api/temoignages");
            Logger.LogInformation($"Loaded {temoignages?.Count} temoignages");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Erreur lors du chargement des données");
            temoignages = new List<TemoignageModel>();
        }
    }

    private void ShowOptionsMenu(string temoignageId)
    {
        Logger.LogInformation($"Showing options menu for temoignage {temoignageId}");
        activeDropdownId = activeDropdownId == temoignageId ? null : temoignageId;
        StateHasChanged();
    }

    private async Task DeleteTemoignage(string temoignageId)
    {
        try
        {
            var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Êtes-vous sûr de vouloir supprimer ce témoignage ? Cette action est irréversible.");
            if (!confirmed)
            {
                return;
            }

            // Vérifier que l'utilisateur est connecté
            if (currentUser == null)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Vous devez être connecté pour supprimer un témoignage.");
                return;
            }

            // Vérifier que l'utilisateur est l'auteur du témoignage
            var temoignage = temoignages?.FirstOrDefault(t => t.Id == temoignageId);
            if (temoignage == null || temoignage.UserId != currentUser.Id)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Vous n'êtes pas autorisé à supprimer ce témoignage.");
                return;
            }

            // Configurer le header d'autorisation
            var token = await AuthService.GetTokenAsync();
            if (string.IsNullOrEmpty(token))
            {
                await JSRuntime.InvokeVoidAsync("alert", "Session expirée. Veuillez vous reconnecter.");
                return;
            }
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            // Envoyer la requête de suppression
            var response = await Http.DeleteAsync($"http://localhost:5175/api/temoignages/{temoignageId}");

            if (response.IsSuccessStatusCode)
            {
                // Supprimer de la liste locale
                temoignages?.RemoveAll(t => t.Id == temoignageId);
                activeDropdownId = null;
                StateHasChanged();
                await JSRuntime.InvokeVoidAsync("alert", "Témoignage supprimé avec succès!");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                throw new Exception($"Erreur lors de la suppression : {error}");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Erreur lors de la suppression du témoignage");
            await JSRuntime.InvokeVoidAsync("alert", $"Erreur lors de la suppression : {ex.Message}");
            StateHasChanged();
        }
    }

    private async Task ShowEditModal(TemoignageModel temoignage)
    {
        if (currentUser?.Id != temoignage.UserId)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Vous n'êtes pas autorisé à modifier ce témoignage.");
            return;
        }

        editingTemoignage = new TemoignageModel
        {
            Id = temoignage.Id,
            UserId = temoignage.UserId,
            Contenu = temoignage.Contenu,
            MotsCles = temoignage.MotsCles,
            FullName = temoignage.FullName,
            Email = temoignage.Email,
            Profession = temoignage.Profession,
            PhotoUrl = temoignage.PhotoUrl,
            Promotion = temoignage.Promotion,
            Date = temoignage.Date
        };

        await JSRuntime.InvokeVoidAsync("openModal", "editTemoignageModal");
        activeDropdownId = null;
    }

    private async Task HandleTemoignageSubmit(TemoignageModel model)
    {
        if (model == null) return;

        try
        {
            if (temoignages == null)
            {
                temoignages = new List<TemoignageModel>();
            }
            temoignages.Insert(0, model);
            StateHasChanged();

            var updatedTemoignages = await Http.GetFromJsonAsync<List<TemoignageModel>>("http://localhost:5175/api/temoignages");
            if (updatedTemoignages != null)
            {
                temoignages = updatedTemoignages;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Erreur lors du rafraîchissement des témoignages");
        }
    }

    private async Task HandleTemoignageEdit(TemoignageModel updatedTemoignage)
    {
        if (updatedTemoignage == null || string.IsNullOrEmpty(updatedTemoignage.Id))
            return;

        try
        {
            var response = await Http.PutAsJsonAsync($"http://localhost:5175/api/temoignages/{updatedTemoignage.Id}", updatedTemoignage);

            if (response.IsSuccessStatusCode)
            {
                var index = temoignages?.FindIndex(t => t.Id == updatedTemoignage.Id) ?? -1;
                if (index != -1 && temoignages != null)
                {
                    temoignages[index] = updatedTemoignage;
                    StateHasChanged();
                    await JSRuntime.InvokeVoidAsync("closeModal", "editTemoignageModal");
                    await JSRuntime.InvokeVoidAsync("alert", "Témoignage modifié avec succès!");
                }
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                throw new Exception($"Erreur lors de la mise à jour : {error}");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Erreur lors de la mise à jour du témoignage");
            errorMessage = $"Erreur lors de la mise à jour du témoignage : {ex.Message}";
            await JSRuntime.InvokeVoidAsync("alert", errorMessage);
        }
    }

    private string FormatDate(DateTime date)
    {
        var difference = DateTime.Now - date;

        if (difference.TotalMinutes < 60)
            return $"{(int)difference.TotalMinutes}min";
        if (difference.TotalHours < 24)
            return $"{(int)difference.TotalHours}h";
        if (difference.TotalDays < 30)
            return $"{(int)difference.TotalDays}j";
        return date.ToString("dd MMM yyyy");
    }

    private string FormatContent(string content)
    {
        if (string.IsNullOrEmpty(content)) return "";
        return content.Replace("\n", "<br>");
    }

    public void Dispose()
    {
        // Nettoyage si nécessaire
    }
}
