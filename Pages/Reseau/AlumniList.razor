@using AlumniConnect.Front.Models
@inject HttpClient Http
@inject NavigationManager Navigation
@inject PromotionService PromotionService
@page "/alumni"
@layout MainLayout
@using System.Net.Http.Json

<link href="css/shared-navbar.css" rel="stylesheet" />
<link href="css/alumni-page.css" rel="stylesheet" />

<SharedNavbar ActivePage="reseau" RequireLogin="false" />

<style>
    .alumni-container {
        height: calc(100vh - 64px);
        overflow: hidden;
        padding: 2rem;
    }

    .content-wrapper {
        display: flex;
        gap: 2rem;
        height: 100%;
    }

    .sidebar {
        position: sticky;
        top: 2rem;
        height: fit-content;
        min-width: 300px;
        max-width: 300px;
        background: white;
        padding: 2rem;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .filter-section {
        margin-top: 1.5rem;
    }

    .filter-label {
        display: block;
        margin-bottom: 0.5rem;
        color: #4a5568;
        font-weight: 500;
    }

    .filter-select {
        width: 100%;
        padding: 0.5rem;
        margin-bottom: 1rem;
        border: 1px solid #e2e8f0;
        border-radius: 0.375rem;
        background-color: white;
        color: #4a5568;
        font-size: 0.875rem;
        transition: all 0.2s;
    }

    .filter-select:hover {
        border-color: #cbd5e0;
    }

    .filter-select:focus {
        outline: none;
        border-color: #48bb78;
        box-shadow: 0 0 0 3px rgba(72, 187, 120, 0.2);
    }

    .main-content {
        flex: 1;
        overflow-y: auto;
        padding-right: 1rem;
        height: calc(100vh - 100px);
    }

    /* Scrollbar styles */
    .main-content::-webkit-scrollbar {
        width: 8px;
    }

    .main-content::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 4px;
    }

    .main-content::-webkit-scrollbar-thumb {
        background: #48bb78;
        border-radius: 4px;
    }

    .main-content::-webkit-scrollbar-thumb:hover {
        background: #38a169;
    }
</style>

<div class="alumni-container">
    <div class="content-wrapper">
        <!-- Sidebar -->
        <aside class="sidebar">
            <h2>
                <span>👥</span>
                Réseau Alumni
            </h2>
            <p>Découvrez et connectez-vous avec tous les membres de notre communauté AlumniConnect.</p>

            <div class="search-section">
                <label class="search-label">🔍 Rechercher</label>
                <input type="text"
                       class="search-input-d"
                       @bind="search"
                       placeholder="Nom, profession..." />
            </div>

            <div class="filter-section">
                <label class="filter-label">🎓 Promotion</label>
                <select class="filter-select" @bind="selectedPromotion">
                    <option value="">Toutes les promotions</option>
                    @if (isLoadingPromotions)
                    {
                        <option disabled>Chargement des promotions...</option>
                    }
                    else if (promotions != null)
                    {
                        @foreach (var promo in promotions.OrderByDescending(p => p.Nom))
                        {
                            <option value="@promo.Nom">@promo.Nom</option>
                        }
                    }
                </select>

                <label class="filter-label">💼 Domaine</label>
                <select class="filter-select" @bind="selectedDomain">
                    <option value="">Tous les domaines</option>
                    @if (domaines != null)
                    {
                        @foreach (var domaine in domaines.OrderBy(d => d))
                        {
                            <option value="@domaine">@domaine</option>
                        }
                    }
                </select>
            </div>

            @if (alumniList != null)
            {
                <div class="stats-card">
                    <div class="stats-number">@alumniList.Count</div>
                    <div class="stats-label">Alumni connectés</div>
                </div>
            }
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <div class="content-header">
                <h1 class="content-title">Notre Communauté</h1>
                <p class="content-subtitle">
                    @if (alumniList != null && !string.IsNullOrWhiteSpace(search))
                    {
                        @($"{alumniListFiltered.Count()} résultat(s) pour \"{search}\"")
                    }
                    else
                    {
                        @("Explorez les profils de nos anciens étudiants")
                    }
                </p>
            </div>

            @if (alumniList == null)
            {
                <div class="loading-state">
                    <div class="loading-spinner"></div>
                    <h3>Chargement des profils...</h3>
                    <p>Veuillez patienter pendant que nous récupérons les informations.</p>
                </div>
            }
            else if (!alumniListFiltered.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">🔍</div>
                    <h3>Aucun alumni trouvé</h3>
                    <p>
                        @if (!string.IsNullOrWhiteSpace(search))
                        {
                            @("Essayez avec d'autres mots-clés ou supprimez les filtres.")
                        }
                        else
                        {
                            @("Il semble qu'aucun alumni ne soit encore enregistré.")
                        }
                    </p>
                </div>
            }
            else
            {
                <div class="alumni-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem;">
                    @foreach (var alumni in alumniListFiltered)
                    {
                        <div class="alumni-card" style="cursor:pointer"
                             @onclick="@(() => GoToAlumniProfile(alumni.Id))">
                            <div class="alumni-header">
                                <div class="alumni-avatar">
                                    @if (!string.IsNullOrEmpty(alumni.PhotoUrl))
                                    {
                                        <img src="@GetFullPhotoUrl(alumni.PhotoUrl)" alt="Photo de @alumni.FullName" />
                                    }
                                    else
                                    {
                                        @(alumni.FullName?.FirstOrDefault() ?? '?')
                                    }
                                </div>
                                <div class="alumni-info">
                                    <h3>@alumni.FullName</h3>
                                    <div class="alumni-profession">@alumni.Profession</div>
                                    <span class="alumni-promotion">
                                        @{
                                            var promotionName = promotions?.FirstOrDefault(p => p.Id.ToString() == alumni.Promotion)?.Nom ?? alumni.Promotion;
                                        }
                                        Promotion @promotionName
                                    </span>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(alumni.Bio))
                            {
                                <div class="alumni-bio">@alumni.Bio</div>
                            }

                            <div class="alumni-contact">
                                <span>📧</span>
                                <span>@alumni.Email</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </main>
    </div>
</div>

@code {
    private List<AlumniModel>? alumniList;
    private string search = "";
    private string selectedPromotion = "";
    private string selectedDomain = "";
    private List<PromotionModel>? promotions;
    private HashSet<string>? domaines;
    private bool isLoadingPromotions = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            alumniList = await Http.GetFromJsonAsync<List<AlumniModel>>("/api/alumni/all") ?? new List<AlumniModel>();
            Console.WriteLine($"Nombre d'alumni chargés : {alumniList.Count}");
            foreach (var alumni in alumniList)
            {
                Console.WriteLine($"Alumni: {alumni.FullName}, Promotion: {alumni.Promotion}, Profession: {alumni.Profession}");
            }
            await LoadPromotions();
            domaines = new HashSet<string>(alumniList.Select(a => a.Profession).Where(d => !string.IsNullOrEmpty(d)));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading alumni: {ex.Message}");
            alumniList = new List<AlumniModel>();
        }
    }

    private IEnumerable<AlumniModel> alumniListFiltered
    {
        get
        {
            var filtered = alumniList?.Where(a =>
                (string.IsNullOrWhiteSpace(search) ||
                 (a.FullName ?? "").Contains(search, StringComparison.OrdinalIgnoreCase) ||
                 (a.Profession ?? "").Contains(search, StringComparison.OrdinalIgnoreCase)) &&
                (string.IsNullOrWhiteSpace(selectedPromotion) ||
                 (a.Promotion ?? "").Equals(selectedPromotion, StringComparison.OrdinalIgnoreCase)) &&
                (string.IsNullOrWhiteSpace(selectedDomain) ||
                 (a.Profession ?? "").Equals(selectedDomain, StringComparison.OrdinalIgnoreCase))
            ) ?? Enumerable.Empty<AlumniModel>();

            Console.WriteLine($"Filtrage - Promotion sélectionnée: {selectedPromotion}");
            Console.WriteLine($"Filtrage - Domaine sélectionné: {selectedDomain}");
            Console.WriteLine($"Nombre d'alumni après filtrage : {filtered.Count()}");
            return filtered;
        }
    }

    private string GetFullPhotoUrl(string? photoUrl)
    {
        if (string.IsNullOrWhiteSpace(photoUrl))
            return "images/default-avatar.png"; // Image par défaut

        // Si l'URL commence déjà par http, on la retourne telle quelle
        if (photoUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase))
            return photoUrl;

        // Sinon, on préfixe avec l'URL du backend
        return $"http://localhost:5175{photoUrl}";
    }

    private void GoToAlumniProfile(string? id)
    {
        if (!string.IsNullOrWhiteSpace(id))
            Navigation.NavigateTo($"/alumni/{id}");
    }

    private async Task LoadPromotions()
    {
        isLoadingPromotions = true;
        StateHasChanged();
        try
        {
            promotions = await PromotionService.GetAllPromotionsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors du chargement des promotions: {ex.Message}");
            promotions = new List<PromotionModel>();
        }
        finally
        {
            isLoadingPromotions = false;
            StateHasChanged();
        }
    }
}
