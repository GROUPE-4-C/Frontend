@page "/alumni/{Id}"
@using AlumniConnect.Front.Models
@inject HttpClient Http
<link href="css/shared-navbar.css" rel="stylesheet" />
<link href="css/alumni-page.css" rel="stylesheet" />
<link href="css/alumni-profile.css" rel="stylesheet" />

<SharedNavbar ActivePage="reseau" RequireLogin="false" />

<div class="alumni-container">
    <div class="content-wrapper">
        <aside class="sidebar">
            <a href="/alumni" class="back-link">
                <i class="fas fa-arrow-left"></i>
                <span>Retour à la liste</span>
            </a>
        </aside>

        <section class="main-content">
            @if (alumni == null)
            {
                <div class="loading-state-modern">
                    <div class="loading-spinner-modern"></div>
                    <p>Chargement du profil...</p>
                </div>
            }
            else
            {
                <div class="alumni-profile-container">
                    <!-- Carte de profil -->
                    <div class="alumni-profile-card">
                        <!-- Avatar avec badge -->
                        <div class="avatar-container">
                            <img class="profile-avatar" src="@GetFullPhotoUrl(alumni.PhotoUrl)" alt="Avatar" />
                            <div class="status-badge online">
                                <i class="fas fa-circle"></i>
                            </div>
                        </div>

                        <!-- Informations principales -->
                        <div class="profile-header">
                            <h2>@alumni.FullName</h2>
                            <div class="profile-title">@alumni.Profession</div>
                            <div class="profile-promo">
                                <i class="fas fa-graduation-cap"></i>
                                @alumni.Promotion
                            </div>
                        </div>

                        <!-- Bio -->
                        @if (!string.IsNullOrEmpty(alumni.Bio))
                        {
                            <div class="profile-bio">
                                <i class="fas fa-quote-left quote-icon"></i>
                                <p>@alumni.Bio</p>
                            </div>
                        }

                        <!-- Statistiques -->
                        <div class="profile-stats">
                            <div class="stat-item">
                                <div class="stat-number">@(emplois?.Count ?? 0)</div>
                                <div class="stat-label">Emplois</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-number">@(events?.Count ?? 0)</div>
                                <div class="stat-label">Événements</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-number">@(temoignages?.Count ?? 0)</div>
                                <div class="stat-label">Témoignages</div>
                            </div>
                        </div>

                        <!-- Contact -->
                        <div class="profile-contact">
                            <div class="contact-item">
                                <i class="fas fa-envelope"></i>
                                <span>@alumni.Email</span>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="profile-actions">
                            <button class="action-btn primary">
                                <i class="fas fa-user-plus"></i>
                                Ajouter au réseau
                            </button>
                            <button class="action-btn secondary">
                                <i class="fas fa-envelope"></i>
                                Contacter
                            </button>
                        </div>
                    </div>

                    <!-- Contenu principal -->
                    <div class="alumni-profile-feed">
                        <!-- Section Parcours Professionnel -->
                        <section class="career-timeline">
                            <div class="section-header">
                                <h3><i class="fas fa-briefcase"></i> Parcours Professionnel</h3>
                            </div>

                            @if (experiences == null)
                            {
                                <div class="loading-content">
                                    <div class="spinner"></div>
                                    <p>Chargement du parcours professionnel...</p>
                                </div>
                            }
                            else if (experiences.Count == 0)
                            {
                                <div class="empty-state">
                                    <div class="empty-icon">
                                        <i class="fas fa-briefcase"></i>
                                    </div>
                                    <h4>Aucune expérience professionnelle</h4>
                                    <p>@alumni.FullName n'a pas encore ajouté d'expériences professionnelles</p>
                                </div>
                            }
                            else
                            {
                                <div class="experience-list-grid">
                                    @foreach (var exp in experiences.OrderByDescending(e => e.DateDebut))
                                    {
                                        <div class="experience-card">
                                            <div class="exp-card-header">
                                                <div class="exp-card-title">
                                                    <strong>@exp.Poste</strong>
                                                    <span class="exp-card-company">@exp.Entreprise</span>
                                                </div>
                                                <span class="exp-card-status">
                                                    @if (exp.EnCours)
                                                    {
                                                        <span class="badge badge-success">En cours</span>
                                                    }
                                                    else if (!string.IsNullOrWhiteSpace(exp.Duree))
                                                    {
                                                        <span class="badge badge-secondary">@exp.Duree</span>
                                                    }
                                                </span>
                                            </div>
                                            <div class="exp-card-dates">
                                                <i class="fas fa-calendar-alt"></i>
                                                <span>
                                                    @exp.DateDebut.ToString("MMM yyyy") -
                                                    @(exp.EnCours ? "Aujourd'hui" : (exp.DateFin.HasValue ? exp.DateFin.Value.ToString("MMM yyyy") : ""))
                                                </span>
                                            </div>
                                            <div class="exp-card-location">
                                                <i class="fas fa-map-marker-alt"></i> @exp.Localisation
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(exp.Description))
                                            {
                                                <div class="exp-card-description">
                                                    @exp.Description
                                                </div>
                                            }
                                            <div class="exp-card-details">
                                                @if (!string.IsNullOrWhiteSpace(exp.TypeContrat))
                                                {
                                                    <span class="exp-card-contrat">Contrat : @exp.TypeContrat</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(exp.Secteur))
                                                {
                                                    <span class="exp-card-secteur">Secteur : @exp.Secteur</span>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </section>

                        <!-- Section Événements -->
                        <section class="events-section">
                            <div class="section-header">
                                <h3><i class="fas fa-calendar-alt"></i> Événements</h3>
                            </div>

                            @if (events == null)
                            {
                                <div class="loading-content">
                                    <div class="spinner"></div>
                                    <p>Chargement des événements...</p>
                                </div>
                            }
                            else if (events.Count == 0)
                            {
                                <div class="empty-state">
                                    <div class="empty-icon">
                                        <i class="fas fa-calendar-alt"></i>
                                    </div>
                                    <h4>Aucun événement</h4>
                                    <p>@alumni.FullName n'a pas encore organisé d'événements</p>
                                </div>
                            }
                            else
                            {
                                <div class="events-grid">
                                    @foreach (var ev in events)
                                    {
                                        <div class="event-card enhanced">
                                            <div class="event-date-badge">
                                                <div class="date-day">@ev.Date.Day</div>
                                                <div class="date-month">@ev.Date.ToString("MMM")</div>
                                            </div>
                                            <div class="event-content">
                                                <h4 class="event-title">@ev.Title</h4>
                                                <div class="event-meta">
                                                    <div class="event-location">
                                                        <i class="fas fa-map-marker-alt"></i>
                                                        <span>@ev.Location</span>
                                                    </div>
                                                </div>
                                                <p class="event-description">@ev.Description</p>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </section>

                        <!-- Section Témoignages -->
                        <section class="testimonials-section">
                            <div class="section-header">
                                <h3><i class="fas fa-star"></i> Témoignages</h3>
                            </div>

                            @if (temoignages == null)
                            {
                                <div class="loading-content">
                                    <div class="spinner"></div>
                                    <p>Chargement des témoignages...</p>
                                </div>
                            }
                            else if (temoignages.Count == 0)
                            {
                                <div class="empty-state">
                                    <div class="empty-icon">
                                        <i class="fas fa-star"></i>
                                    </div>
                                    <h4>Aucun témoignage</h4>
                                    <p>@alumni.FullName n'a pas encore partagé de témoignages</p>
                                </div>
                            }
                            else
                            {
                                <div class="testimonials-list">
                                    @foreach (var temoignage in temoignages)
                                    {
                                        <div class="testimonial-card">
                                            <div class="testimonial-content">
                                                <div class="quote-mark">
                                                    <i class="fas fa-quote-left"></i>
                                                </div>
                                                <p class="testimonial-text">@temoignage.Contenu</p>
                                            </div>
                                            <div class="testimonial-footer">
                                                <div class="testimonial-date">
                                                    <i class="fas fa-calendar"></i>
                                                    @temoignage.Date.ToString("dd MMM yyyy")
                                                </div>
                                                @if (!string.IsNullOrEmpty(temoignage.MotsCles))
                                                {
                                                    <div class="testimonial-tags">
                                                        @foreach (var tag in temoignage.MotsCles.Split(','))
                                                        {
                                                            <span class="tag">@tag.Trim()</span>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </section>
                    </div>
                </div>
            }
        </section>
    </div>
</div>

<style>
    .experience-list-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 1.5rem;
        margin-top: 1.5rem;
    }
    .experience-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.07);
        padding: 1.5rem 1.2rem;
        display: flex;
        flex-direction: column;
        transition: box-shadow 0.2s;
        border: 1px solid #e2e8f0;
        min-height: 220px;
        position: relative;
    }
    .experience-card:hover {
        box-shadow: 0 4px 16px rgba(0,0,0,0.13);
        border-color: #cbd5e1;
    }
    .exp-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.7rem;
    }
    .exp-card-title {
        display: flex;
        flex-direction: column;
    }
    .exp-card-title strong {
        font-size: 1.18rem;
        color: #2d3748;
    }
    .exp-card-company {
        color: #4a5568;
        font-size: 1rem;
        margin-top: 2px;
        font-weight: 500;
    }
    .exp-card-status .badge {
        font-size: 0.95rem;
        padding: 0.2em 0.7em;
        border-radius: 8px;
        margin-left: 0.5em;
        font-weight: 500;
        letter-spacing: 0.5px;
    }
    .badge-success {
        background: #38a169;
        color: #fff;
    }
    .badge-secondary {
        background: #a0aec0;
        color: #fff;
    }
    .exp-card-dates, .exp-card-location {
        font-size: 0.98rem;
        color: #718096;
        margin-bottom: 0.4rem;
        display: flex;
        align-items: center;
        gap: 0.4em;
    }
    .exp-card-description {
        margin: 0.7rem 0;
        color: #2d3748;
        font-size: 1.05rem;
        line-height: 1.6;
    }
    .exp-card-details {
        display: flex;
        gap: 1.2em;
        font-size: 0.97rem;
        color: #4a5568;
        margin-top: 0.5rem;
    }
    .exp-card-contrat, .exp-card-secteur {
        background: #edf2f7;
        padding: 0.2em 0.7em;
        border-radius: 7px;
        font-size: 0.97rem;
        font-weight: 500;
    }
    @@media (max-width: 700px) {
        .experience-list-grid {
            grid-template-columns: 1fr;
        }
        .experience-card {
            padding: 1.1rem 0.7rem;
        }
    }
</style>

@code {
    [Parameter] public string Id { get; set; } = string.Empty;
    private AlumniModel? alumni;
    private List<EmploiModel>? emplois;
    private List<EventModel>? events;
    private List<TemoignageModel>? temoignages;
    private List<ExperienceModel>? experiences;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(Id))
        {
            try
            {
                alumni = await Http.GetFromJsonAsync<AlumniModel>($"/api/alumni/{Id}");
                emplois = await Http.GetFromJsonAsync<List<EmploiModel>>($"/api/emplois/user/{Id}");
                temoignages = await Http.GetFromJsonAsync<List<TemoignageModel>>($"/api/temoignages/user/{Id}");
                events = await Http.GetFromJsonAsync<List<EventModel>>($"/api/events/user/{Id}");
                experiences = await Http.GetFromJsonAsync<List<ExperienceModel>>($"/api/experiences/user/{Id}");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Erreur lors du chargement des données alumni: {ex.Message}");
            }
        }
    }

    private string GetFullPhotoUrl(string? photoUrl)
    {
        if (string.IsNullOrWhiteSpace(photoUrl))
            return "images/default-avatar.png";

        if (photoUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase))
            return photoUrl;

        return $"http://localhost:5175{photoUrl}";
    }

    private string GetDuration(DateTime start, DateTime end)
    {
        var diff = end - start;
        var years = diff.Days / 365;
        var months = (diff.Days % 365) / 30;

        if (years > 0)
            return months > 0 ? $"{years}a {months}m" : $"{years}a";

        return months > 0 ? $"{months}m" : "< 1m";
    }
}
