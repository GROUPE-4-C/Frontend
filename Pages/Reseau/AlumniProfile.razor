@page "/alumni/{Id}"
@using AlumniConnect.Front.Models
@inject HttpClient Http
<link href="css/shared-navbar.css" rel="stylesheet" />
<link href="css/alumni-page.css" rel="stylesheet" />
<link href="css/alumni-profile.css" rel="stylesheet" />

<SharedNavbar ActivePage="reseau" RequireLogin="false" />

<div class="alumni-container">
    <div class="content-wrapper">
        <aside class="sidebar">
            <a href="/alumni" class="back-link">
                <i class="fas fa-arrow-left"></i>
                <span>Retour à la liste</span>
            </a>
        </aside>

        <section class="main-content">
            @if (alumni == null)
            {
                <div class="loading-state-modern">
                    <div class="loading-spinner-modern"></div>
                    <p>Chargement du profil...</p>
                </div>
            }
            else
            {
                <div class="alumni-profile-container">
                    <!-- Carte de profil -->
                    <div class="alumni-profile-card">
                        <!-- Avatar avec badge -->
                        <div class="avatar-container">
                            <img class="profile-avatar" src="@GetFullPhotoUrl(alumni.PhotoUrl)" alt="Avatar" />
                            <div class="status-badge online">
                                <i class="fas fa-circle"></i>
                            </div>
                        </div>

                        <!-- Informations principales -->
                        <div class="profile-header">
                            <h2>@alumni.FullName</h2>
                            <div class="profile-title">@alumni.Profession</div>
                            <div class="profile-promo">
                                <i class="fas fa-graduation-cap"></i>
                                @alumni.Promotion
                            </div>
                        </div>

                        <!-- Bio -->
                        @if (!string.IsNullOrEmpty(alumni.Bio))
                        {
                            <div class="profile-bio">
                                <i class="fas fa-quote-left quote-icon"></i>
                                <p>@alumni.Bio</p>
                            </div>
                        }

                        <!-- Statistiques -->
                        <div class="profile-stats">
                            <div class="stat-item">
                                <div class="stat-number">@(emplois?.Count ?? 0)</div>
                                <div class="stat-label">Emplois</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-number">@(events?.Count ?? 0)</div>
                                <div class="stat-label">Événements</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-number">@(temoignages?.Count ?? 0)</div>
                                <div class="stat-label">Témoignages</div>
                            </div>
                        </div>

                        <!-- Contact -->
                        <div class="profile-contact">
                            <div class="contact-item">
                                <i class="fas fa-envelope"></i>
                                <span>@alumni.Email</span>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="profile-actions">
                            <button class="action-btn primary">
                                <i class="fas fa-user-plus"></i>
                                Ajouter au réseau
                            </button>
                            <button class="action-btn secondary">
                                <i class="fas fa-envelope"></i>
                                Contacter
                            </button>
                        </div>
                    </div>

                    <!-- Contenu principal -->
                    <div class="alumni-profile-feed">
                        <!-- Section Parcours Professionnel -->
                        <section class="career-timeline">
                            <div class="section-header">
                                <h3><i class="fas fa-briefcase"></i> Parcours Professionnel</h3>
                            </div>

                            @if (emplois == null)
                            {
                                <div class="loading-content">
                                    <div class="spinner"></div>
                                    <p>Chargement du parcours professionnel...</p>
                                </div>
                            }
                            else if (emplois.Count == 0)
                            {
                                <div class="empty-state">
                                    <div class="empty-icon">
                                        <i class="fas fa-briefcase"></i>
                                    </div>
                                    <h4>Aucune expérience professionnelle</h4>
                                    <p>@alumni.FullName n'a pas encore ajouté d'expériences professionnelles</p>
                                </div>
                            }
                            else
                            {
                                <div class="timeline">
                                    @foreach (var (emploi, index) in emplois.Select((e, i) => (e, i)))
                                    {
                                        <div class="timeline-item @(index == 0 ? "current" : "")">
                                            <div class="timeline-marker">
                                                <div class="timeline-dot @(index == 0 ? "active" : "")">
                                                    @if (index == 0)
                                                    {
                                                        <i class="fas fa-circle"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="fas fa-check"></i>
                                                    }
                                                </div>
                                            </div>
                                            <div class="timeline-content">
                                                <div class="emploi-card enhanced">
                                                    <div class="emploi-header">
                                                        <div class="emploi-main-info">
                                                            <h4 class="emploi-title">@emploi.Titre</h4>
                                                            <p class="emploi-company">
                                                                <i class="fas fa-building"></i>
                                                                @emploi.Entreprise
                                                            </p>
                                                        </div>
                                                        <div class="emploi-duration">
                                                            <span class="duration-badge @(index == 0 ? "current" : "")">
                                                                @if (index == 0)
                                                                {
                                                                    <i class="fas fa-clock"></i>
                                                                    <span>En cours</span>
                                                                }
                                                                else
                                                                {
                                                                    <span>@GetDuration(emploi.DateDebut, emploi.DateFin)</span>
                                                                }
                                                            </span>
                                                        </div>
                                                    </div>

                                                    <div class="emploi-period">
                                                        <i class="fas fa-calendar-alt"></i>
                                                        <span>@emploi.DateDebut.ToString("MMM yyyy") - @emploi.DateFin.ToString("MMM yyyy")</span>
                                                    </div>

                                                    @if (!string.IsNullOrEmpty(emploi.Description))
                                                    {
                                                        <div class="emploi-description">
                                                            @emploi.Description
                                                        </div>
                                                    }

                                                    @if (!string.IsNullOrEmpty(emploi.Localisation))
                                                    {
                                                        <div class="emploi-location">
                                                            <i class="fas fa-map-marker-alt"></i>
                                                            <span>@emploi.Localisation</span>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </section>

                        <!-- Section Événements -->
                        <section class="events-section">
                            <div class="section-header">
                                <h3><i class="fas fa-calendar-alt"></i> Événements</h3>
                            </div>

                            @if (events == null)
                            {
                                <div class="loading-content">
                                    <div class="spinner"></div>
                                    <p>Chargement des événements...</p>
                                </div>
                            }
                            else if (events.Count == 0)
                            {
                                <div class="empty-state">
                                    <div class="empty-icon">
                                        <i class="fas fa-calendar-alt"></i>
                                    </div>
                                    <h4>Aucun événement</h4>
                                    <p>@alumni.FullName n'a pas encore organisé d'événements</p>
                                </div>
                            }
                            else
                            {
                                <div class="events-grid">
                                    @foreach (var ev in events)
                                    {
                                        <div class="event-card enhanced">
                                            <div class="event-date-badge">
                                                <div class="date-day">@ev.Date.Day</div>
                                                <div class="date-month">@ev.Date.ToString("MMM")</div>
                                            </div>
                                            <div class="event-content">
                                                <h4 class="event-title">@ev.Title</h4>
                                                <div class="event-meta">
                                                    <div class="event-location">
                                                        <i class="fas fa-map-marker-alt"></i>
                                                        <span>@ev.Location</span>
                                                    </div>
                                                </div>
                                                <p class="event-description">@ev.Description</p>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </section>

                        <!-- Section Témoignages -->
                        <section class="testimonials-section">
                            <div class="section-header">
                                <h3><i class="fas fa-star"></i> Témoignages</h3>
                            </div>

                            @if (temoignages == null)
                            {
                                <div class="loading-content">
                                    <div class="spinner"></div>
                                    <p>Chargement des témoignages...</p>
                                </div>
                            }
                            else if (temoignages.Count == 0)
                            {
                                <div class="empty-state">
                                    <div class="empty-icon">
                                        <i class="fas fa-star"></i>
                                    </div>
                                    <h4>Aucun témoignage</h4>
                                    <p>@alumni.FullName n'a pas encore partagé de témoignages</p>
                                </div>
                            }
                            else
                            {
                                <div class="testimonials-list">
                                    @foreach (var temoignage in temoignages)
                                    {
                                        <div class="testimonial-card">
                                            <div class="testimonial-content">
                                                <div class="quote-mark">
                                                    <i class="fas fa-quote-left"></i>
                                                </div>
                                                <p class="testimonial-text">@temoignage.Contenu</p>
                                            </div>
                                            <div class="testimonial-footer">
                                                <div class="testimonial-date">
                                                    <i class="fas fa-calendar"></i>
                                                    @temoignage.Date.ToString("dd MMM yyyy")
                                                </div>
                                                @if (!string.IsNullOrEmpty(temoignage.MotsCles))
                                                {
                                                    <div class="testimonial-tags">
                                                        @foreach (var tag in temoignage.MotsCles.Split(','))
                                                        {
                                                            <span class="tag">@tag.Trim()</span>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </section>
                    </div>
                </div>
            }
        </section>
    </div>
</div>

@code {
    [Parameter] public string Id { get; set; } = string.Empty;
    private AlumniModel? alumni;
    private List<EmploiModel>? emplois;
    private List<EventModel>? events;
    private List<TemoignageModel>? temoignages;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(Id))
        {
            try
            {
                alumni = await Http.GetFromJsonAsync<AlumniModel>($"/api/alumni/{Id}");
                emplois = await Http.GetFromJsonAsync<List<EmploiModel>>($"/api/emplois/user/{Id}");
                temoignages = await Http.GetFromJsonAsync<List<TemoignageModel>>($"/api/temoignages/user/{Id}");
                events = await Http.GetFromJsonAsync<List<EventModel>>($"/api/events/user/{Id}");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Erreur lors du chargement des données alumni: {ex.Message}");
            }
        }
    }

    private string GetFullPhotoUrl(string? photoUrl)
    {
        if (string.IsNullOrWhiteSpace(photoUrl))
            return "images/default-avatar.png";

        if (photoUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase))
            return photoUrl;

        return $"http://localhost:5175{photoUrl}";
    }

    private string GetDuration(DateTime start, DateTime end)
    {
        var diff = end - start;
        var years = diff.Days / 365;
        var months = (diff.Days % 365) / 30;

        if (years > 0)
            return months > 0 ? $"{years}a {months}m" : $"{years}a";

        return months > 0 ? $"{months}m" : "< 1m";
    }
}
