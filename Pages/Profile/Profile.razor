@page "/profile"
@using AlumniConnect.Front.Models
@using AlumniConnect.Front.Components.Experience
@inject AlumniConnect.Front.Services.AuthService AuthService
@inject HttpClient Http
@inject IJSRuntime JS

<SharedNavbar ActivePage="profile" RequireLogin="true" />
<link href="css/profile.css" rel="stylesheet" />
<link href="css/shared-navbar.css" rel="stylesheet" />
<link href="css/body-layout.css" rel="stylesheet" />
<link href="css/dashboard.css" rel="stylesheet" />
<link href="css/modal-forms.css" rel="stylesheet" />
<script src="js/modals.js"></script>

<div class="main-container">
    <aside class="profile-card">
        @if (User != null)
        {
            <!-- Photo de profil avec badge de statut -->
            <div class="avatar-container">
                <img class="profile-avatar" src="@GetFullPhotoUrl(User.PhotoUrl)" alt="Avatar" />
                <div class="status-badge online">
                    <i class="fas fa-circle"></i>
                </div>
            </div>

            <!-- Informations principales -->
            <div class="profile-header">
                <h2>@User.FullName</h2>
                <div class="profile-title">@User.Profession</div>
                <div class="profile-promo">
                    <i class="fas fa-graduation-cap"></i>
                    @User.Promotion
                </div>
            </div>

            <!-- Bio avec style amélioré -->
            @if (!string.IsNullOrEmpty(User.Bio))
            {
                <div class="profile-bio">
                    <i class="fas fa-quote-left quote-icon"></i>
                    <p>@User.Bio</p>
                </div>
            }

            <!-- Contact et statistiques -->
            <div class="profile-stats">
                <div class="stat-item">
                    <div class="stat-number">@(Emplois?.Count ?? 0)</div>
                    <div class="stat-label">Emplois</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">@(Events?.Count ?? 0)</div>
                    <div class="stat-label">Événements</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">@(Temoignages?.Count ?? 0)</div>
                    <div class="stat-label">Témoignages</div>
                </div>
            </div>

            <div class="profile-contact">
                <div class="contact-item">
                    <i class="fas fa-envelope"></i>
                    <span>@User.Email</span>
                </div>
                @if (!string.IsNullOrEmpty(User.PhoneNumber))
                {
                    <div class="contact-item">
                        <i class="fas fa-phone"></i>
                        <span>@User.PhoneNumber</span>
                    </div>
                }
            </div>

            <!-- Actions rapides -->
            <div class="profile-actions">
                <button class="action-btn primary">
                    <i class="fas fa-edit"></i>
                    Modifier le profil
                </button>
                <button class="action-btn secondary">
                    <i class="fas fa-share-alt"></i>
                    Partager
                </button>
            </div>
        }
        else
        {
            <div class="loading-skeleton">
                <div class="skeleton-avatar"></div>
                <div class="skeleton-text"></div>
                <div class="skeleton-text short"></div>
            </div>
        }
    </aside>

    <main class="profile-feed">
        <!-- Section Parcours Professionnel -->
        <!-- Formulaire modal pour ajouter une expérience -->
        @using AlumniConnect.Front.Components.Forms
        <ExperienceForm ModalId="createExperienceModal"
                        ExperienceModel="@newExperience"
                        OnSubmit="@OnExperienceAdded"
                        IsSubmitting="@isSubmittingExperience" />

        <section class="career-timeline">
            <div class="section-header">
                <h3><i class="fas fa-briefcase"></i> Parcours Professionnel</h3>
                <button class="add-btn" onclick="openModal('createExperienceModal')">
                    <i class="fas fa-plus"></i>
                    Ajouter
                </button>
            </div>

            @if (Experiences == null)
            {
                <div class="loading-content">
                    <div class="spinner"></div>
                    <p>Chargement du parcours professionnel...</p>
                </div>
            }
            else if (Experiences.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="fas fa-briefcase"></i>
                    </div>
                    <h4>Aucune expérience professionnelle</h4>
                    <p>Ajoutez vos expériences pour enrichir votre profil</p>
                    <button class="btn-primary">
                        <i class="fas fa-plus"></i>
                        Ajouter une expérience
                    </button>
                </div>
            }
            else
            {
                <ExperienceList
                    Experiences="@Experiences"
                    IsOwner="@(isCurrentUserProfile)"
                    OnExperienceUpdated="@HandleExperienceUpdated" />
            }
        </section>
        <style>
            .experience-list-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
                gap: 1.5rem;
                margin-top: 1.5rem;
            }
            .experience-card {
                background: #fff;
                border-radius: 12px;
                box-shadow: 0 2px 8px rgba(0,0,0,0.07);
                padding: 1.5rem 1.2rem;
                display: flex;
                flex-direction: column;
                transition: box-shadow 0.2s;
                border: 1px solid #e2e8f0;
            }
            .experience-card:hover {
                box-shadow: 0 4px 16px rgba(0,0,0,0.13);
                border-color: #cbd5e1;
            }
            .exp-card-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 0.7rem;
            }
            .exp-card-title {
                display: flex;
                flex-direction: column;
            }
            .exp-card-company {
                color: #4a5568;
                font-size: 1rem;
                margin-top: 2px;
            }
            .exp-card-status .badge {
                font-size: 0.95rem;
                padding: 0.2em 0.7em;
                border-radius: 8px;
                margin-left: 0.5em;
            }
            .badge-success {
                background: #38a169;
                color: #fff;
            }
            .badge-secondary {
                background: #a0aec0;
                color: #fff;
            }
            .exp-card-dates, .exp-card-location {
                font-size: 0.98rem;
                color: #718096;
                margin-bottom: 0.4rem;
                display: flex;
                align-items: center;
                gap: 0.4em;
            }
            .exp-card-description {
                margin: 0.7rem 0;
                color: #2d3748;
                font-size: 1.05rem;
            }
            .exp-card-details {
                display: flex;
                gap: 1.2em;
                font-size: 0.97rem;
                color: #4a5568;
                margin-top: 0.5rem;
            }
            .exp-card-contrat, .exp-card-secteur {
                background: #edf2f7;
                padding: 0.2em 0.7em;
                border-radius: 7px;
            }
        </style>

        <!-- Section Événements -->
        <section class="events-section">
            <div class="section-header">
                <h3><i class="fas fa-calendar-alt"></i> Mes Événements</h3>
                <button class="add-btn">
                    <i class="fas fa-plus"></i>
                    Ajouter
                </button>
            </div>

            @if (Events == null)
            {
                <div class="loading-content">
                    <div class="spinner"></div>
                    <p>Chargement des événements...</p>
                </div>
            }
            else if (Events.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="fas fa-calendar-alt"></i>
                    </div>
                    <h4>Aucun événement</h4>
                    <p>Organisez ou participez à des événements pour développer votre réseau</p>
                </div>
            }
            else
            {
                <div class="events-grid">
                    @foreach (var ev in Events)
                    {
                        <div class="event-card enhanced">
                            <div class="event-date-badge">
                                <div class="date-day">@ev.Date.Day</div>
                                <div class="date-month">@ev.Date.ToString("MMM")</div>
                            </div>
                            <div class="event-content">
                                <h4 class="event-title">@ev.Title</h4>
                                <div class="event-meta">
                                    <div class="event-location">
                                        <i class="fas fa-map-marker-alt"></i>
                                        <span>@ev.Location</span>
                                    </div>
                                </div>
                                <p class="event-description">@ev.Description</p>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>

        <!-- Section Témoignages -->
        <section class="testimonials-section">
            <div class="section-header">
                <h3><i class="fas fa-star"></i> Mes Témoignages</h3>
                <button class="add-btn">
                    <i class="fas fa-plus"></i>
                    Ajouter
                </button>
            </div>

            @if (Temoignages == null)
            {
                <div class="loading-content">
                    <div class="spinner"></div>
                    <p>Chargement des témoignages...</p>
                </div>
            }
            else if (Temoignages.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="fas fa-star"></i>
                    </div>
                    <h4>Aucun témoignage</h4>
                    <p>Partagez votre expérience pour inspirer d'autres alumni</p>
                </div>
            }
            else
            {
                <div class="testimonials-list">
                    @foreach (var temoignage in Temoignages)
                    {
                        <div class="testimonial-card">
                            <div class="testimonial-content">
                                <div class="quote-mark">
                                    <i class="fas fa-quote-left"></i>
                                </div>
                                <p class="testimonial-text">@temoignage.Contenu</p>
                            </div>
                            <div class="testimonial-footer">
                                <div class="testimonial-date">
                                    <i class="fas fa-calendar"></i>
                                    @temoignage.Date.ToString("dd MMM yyyy")
                                </div>
                                @if (!string.IsNullOrEmpty(temoignage.MotsCles))
                                {
                                    <div class="testimonial-tags">
                                        @foreach (var tag in temoignage.MotsCles.Split(','))
                                        {
                                            <span class="tag">@tag.Trim()</span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    </main>
</div>

@code {
    UserInfo? User;
    List<EmploiModel>? Emplois;
    List<EventModel>? Events;
    List<TemoignageModel>? Temoignages;
    List<ExperienceModel>? Experiences;

    // Pour le formulaire d'ajout d'expérience
    ExperienceModel newExperience = new ExperienceModel
    {
        DateDebut = DateTime.Today,
        DateFin = DateTime.Today,
        EnCours = false
    };
    bool isSubmittingExperience = false;

    // Réinitialise le modèle à chaque ouverture du modal (UX parfaite)
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
            return;
        var modal = JS.InvokeAsync<bool>("eval", "document.getElementById('createExperienceModal')?.style.display === 'flex'");
        modal.AsTask().ContinueWith(task =>
        {
            if (task.Result)
            {
                newExperience = new ExperienceModel
                {
                    DateDebut = DateTime.Today,
                    DateFin = DateTime.Today,
                    EnCours = false
                };
                StateHasChanged();
            }
        });
    }

    private async Task OnExperienceAdded(ExperienceModel exp)
    {
        isSubmittingExperience = true;
        try
        {
            if (Experiences == null)
                Experiences = new List<ExperienceModel>();
            Experiences.Insert(0, exp);
            StateHasChanged();
        }
        finally
        {
            isSubmittingExperience = false;
        }
    }

    private string GetFullPhotoUrl(string? photoUrl)
    {
        if (string.IsNullOrWhiteSpace(photoUrl))
            return "images/default-avatar.png";

        if (photoUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase))
            return photoUrl;

        return $"http://localhost:5175{photoUrl}";
    }

    private string GetDuration(DateTime start, DateTime end)
    {
        var diff = end - start;
        var years = diff.Days / 365;
        var months = (diff.Days % 365) / 30;

        if (years > 0)
            return months > 0 ? $"{years}a {months}m" : $"{years}a";

        return months > 0 ? $"{months}m" : "< 1m";
    }

    private bool isCurrentUserProfile;

    private async Task HandleExperienceUpdated(ExperienceModel updatedExperience)
    {
        // Mettre à jour l'expérience dans la liste locale
        var index = Experiences?.FindIndex(e => e.Id == updatedExperience.Id) ?? -1;
        if (index != -1 && Experiences != null)
        {
            Experiences[index] = updatedExperience;
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        User = await AuthService.GetCurrentUserAsync();
        isCurrentUserProfile = true; // Since this is the profile page, current user is always the owner
        if (User != null)
        {
            // Appels API pour récupérer les contenus de l'utilisateur
            Emplois = await Http.GetFromJsonAsync<List<EmploiModel>>($"/api/emplois/user/{User.Id}");
            Events = await Http.GetFromJsonAsync<List<EventModel>>($"/api/events/user/{User.Id}");
            Temoignages = await Http.GetFromJsonAsync<List<TemoignageModel>>($"/api/temoignages/user/{User.Id}");

            // Récupérer le token d'authentification
            var token = await AuthService.GetTokenAsync();
            if (!string.IsNullOrEmpty(token))
            {
                var request = new HttpRequestMessage(HttpMethod.Get, "/api/experiences/mes-experiences");
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                var response = await Http.SendAsync(request);
                if (response.IsSuccessStatusCode)
                {
                    Experiences = await response.Content.ReadFromJsonAsync<List<ExperienceModel>>();
                }
                else
                {
                    Experiences = new List<ExperienceModel>();
                }
            }
            else
            {
                Experiences = new List<ExperienceModel>();
            }
        }
    }
}
