@code {
    private UserInfo? User { get; set; }
    private List<EmploiModel>? Emplois { get; set; }
    private List<EventModel>? Events { get; set; }
    private List<TemoignageModel>? Temoignages { get; set; }
    private List<ExperienceModel>? Experiences { get; set; }

    // Pour le formulaire d'ajout d'expérience
    private ExperienceModel newExperience = new ExperienceModel();
    private bool isSubmittingExperience = false;

    // Pour les événements
    private EventModel newEvent = new EventModel();
    private bool isSubmittingEvent = false;
    private EventModel eventToEdit = new EventModel();
    private bool isSubmittingEditEvent = false;

    // Pour les témoignages
    private TemoignageModel newTemoignage = new TemoignageModel();
    private bool isSubmittingTemoignage = false;
    private TemoignageModel temoignageToEdit = new TemoignageModel();
    private bool isSubmittingEditTemoignage = false;

    // Pour les offres d'emploi
    private EmploiModel newEmploi = new EmploiModel();
    private bool isSubmittingNewEmploi = false;
    private EmploiModel emploiToEdit = new EmploiModel();
    private bool isSubmittingEditEmploi = false;
    private Guid? openedEmploiMenuId = null;
    private void ToggleEmploiMenu(Guid id) => openedEmploiMenuId = openedEmploiMenuId == id ? null : id;
    private void CloseEmploiMenu() => openedEmploiMenuId = null;

    private void OpenEditEmploiModal(EmploiModel emploi)
    {
        emploiToEdit = new EmploiModel
        {
            Id = emploi.Id,
            Titre = emploi.Titre,
            Description = emploi.Description,
            Entreprise = emploi.Entreprise,
            Localisation = emploi.Localisation,
            DateDebut = emploi.DateDebut,
            DateFin = emploi.DateFin,
            ImageUrl = emploi.ImageUrl,
            EstActif = emploi.EstActif
        };
        JS.InvokeVoidAsync("openModal", "editEmploiModal");
    }

    private async Task HandleEmploiSubmit(EmploiModel emploi)
    {
        if (isSubmittingNewEmploi) return;
        isSubmittingNewEmploi = true;

        try
        {
            var token = await AuthService.GetTokenAsync();
            if (string.IsNullOrEmpty(token))
                return;

            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            var response = await Http.PostAsJsonAsync("http://localhost:5175/api/emplois", emploi);

            if (response.IsSuccessStatusCode)
            {
                var createdEmploi = await response.Content.ReadFromJsonAsync<EmploiModel>();
                if (createdEmploi != null)
                {
                    if (Emplois == null) Emplois = new List<EmploiModel>();
                    Emplois.Insert(0, createdEmploi);
                    await JS.InvokeVoidAsync("closeModal", "createEmploiModal");
                    await JS.InvokeVoidAsync("alert", "Offre d'emploi créée avec succès !");
                    StateHasChanged();
                }
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Erreur lors de la création de l'offre d'emploi.");
            Console.WriteLine($"Erreur: {ex.Message}");
        }
        finally
        {
            isSubmittingNewEmploi = false;
        }
    }

    private async Task HandleEmploiEdit(EmploiModel emploi)
    {
        if (isSubmittingEditEmploi) return;
        isSubmittingEditEmploi = true;

        try
        {
            var token = await AuthService.GetTokenAsync();
            if (string.IsNullOrEmpty(token))
                return;

            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            var response = await Http.PutAsJsonAsync($"http://localhost:5175/api/emplois/{emploi.Id}", emploi);

            if (response.IsSuccessStatusCode)
            {
                var updatedEmploi = await response.Content.ReadFromJsonAsync<EmploiModel>();
                if (updatedEmploi != null && Emplois != null)
                {
                    var index = Emplois.FindIndex(e => e.Id == updatedEmploi.Id);
                    if (index != -1)
                    {
                        Emplois[index] = updatedEmploi;
                        await JS.InvokeVoidAsync("closeModal", "editEmploiModal");
                        await JS.InvokeVoidAsync("alert", "Offre d'emploi modifiée avec succès !");
                        StateHasChanged();
                    }
                }
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Erreur lors de la modification de l'offre d'emploi.");
            Console.WriteLine($"Erreur: {ex.Message}");
        }
        finally
        {
            isSubmittingEditEmploi = false;
        }
    }

    // Gestion du menu à trois points pour événements
    private Guid? openedEventMenuId = null;
    private void ToggleEventMenu(Guid id) => openedEventMenuId = openedEventMenuId == id ? null : id;
    private void CloseEventMenu() => openedEventMenuId = null;

    // Gestion du menu à trois points pour témoignages
    private string? openedTemoignageMenuId = null;
    private void ToggleTemoignageMenu(string id) => openedTemoignageMenuId = openedTemoignageMenuId == id ? null : id;
    private void CloseTemoignageMenu() => openedTemoignageMenuId = null;

    private bool isCurrentUserProfile;

    protected override async Task OnInitializedAsync()
    {
        User = await AuthService.GetCurrentUserAsync();
        isCurrentUserProfile = true; // Since this is the profile page, current user is always the owner

        if (User != null)
        {
            var token = await AuthService.GetTokenAsync();

            // Récupérer les offres d'emploi
            Emplois = await Http.GetFromJsonAsync<List<EmploiModel>>($"http://localhost:5175/api/emplois/user/{User.Id}");

            // Récupérer les événements
            Events = await Http.GetFromJsonAsync<List<EventModel>>($"http://localhost:5175/api/events/user/{User.Id}");

            // Récupérer les témoignages
            Temoignages = await Http.GetFromJsonAsync<List<TemoignageModel>>($"http://localhost:5175/api/temoignages/user/{User.Id}");

            if (!string.IsNullOrEmpty(token))
            {
                var request = new HttpRequestMessage(HttpMethod.Get, "http://localhost:5175/api/experiences/mes-experiences");
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                var response = await Http.SendAsync(request);
                if (response.IsSuccessStatusCode)
                {
                    Experiences = await response.Content.ReadFromJsonAsync<List<ExperienceModel>>();
                }
                else
                {
                    Experiences = new List<ExperienceModel>();
                }
            }
            else
            {
                Experiences = new List<ExperienceModel>();
            }
        }
    }

    private string GetFullPhotoUrl(string? photoUrl)
    {
        if (string.IsNullOrWhiteSpace(photoUrl))
            return "images/default-avatar.png";

        if (photoUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase))
            return photoUrl;

        return $"http://localhost:5175{photoUrl}";
    }

    private async Task OnExperienceAdded(ExperienceModel exp)
    {
        isSubmittingExperience = true;
        try
        {
            if (Experiences == null)
                Experiences = new List<ExperienceModel>();
            Experiences.Insert(0, exp);
            StateHasChanged();
        }
        finally
        {
            isSubmittingExperience = false;
        }
    }

    private async Task HandleExperienceUpdated(ExperienceModel updatedExperience)
    {
        var index = Experiences?.FindIndex(e => e.Id == updatedExperience.Id) ?? -1;
        if (index != -1 && Experiences != null)
        {
            Experiences[index] = updatedExperience;
            StateHasChanged();
        }
    }

    private async Task OnEventAdded(EventModel ev)
    {
        isSubmittingEvent = true;
        try
        {
            if (Events == null)
                Events = new List<EventModel>();
            Events.Insert(0, ev);
            StateHasChanged();
        }
        finally
        {
            isSubmittingEvent = false;
        }
    }

    private async Task OnEventEdited(EventModel editedEvent)
    {
        isSubmittingEditEvent = true;
        try
        {
            var idx = Events?.FindIndex(e => e.Id == editedEvent.Id) ?? -1;
            if (idx != -1 && Events != null)
            {
                Events[idx] = editedEvent;
                StateHasChanged();
            }
        }
        finally
        {
            isSubmittingEditEvent = false;
        }
    }

    private async Task DeleteEvent(Guid eventId)
    {
        try
        {
            var token = await AuthService.GetTokenAsync();
            if (string.IsNullOrEmpty(token))
                return;

            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            var response = await Http.DeleteAsync($"http://localhost:5175/api/events/{eventId}");

            if (response.IsSuccessStatusCode)
            {
                Events?.RemoveAll(e => e.Id == eventId);
                StateHasChanged();
            }
            else
            {
                Console.WriteLine($"Erreur lors de la suppression : {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception lors de la suppression : {ex.Message}");
        }
    }

    private void OpenEditEventModal(EventModel ev)
    {
        eventToEdit = new EventModel
        {
            Id = ev.Id,
            Title = ev.Title,
            Organizer = ev.Organizer,
            Date = ev.Date,
            Location = ev.Location,
            Description = ev.Description,
            ImageUrl = ev.ImageUrl
        };
        JS.InvokeVoidAsync("openModal", "editEventModal");
    }

    private async Task OnTemoignageAdded(TemoignageModel temoignage)
    {
        isSubmittingTemoignage = true;
        try
        {
            if (Temoignages == null)
                Temoignages = new List<TemoignageModel>();
            Temoignages.Insert(0, temoignage);
            StateHasChanged();
        }
        finally
        {
            isSubmittingTemoignage = false;
        }
    }

    private void OpenTemoignageModal(TemoignageModel temoignage)
    {
        temoignageToEdit = new TemoignageModel
        {
            Id = temoignage.Id,
            Contenu = temoignage.Contenu,
            MotsCles = temoignage.MotsCles,
            Date = temoignage.Date,
            UserId = temoignage.UserId,
            FullName = temoignage.FullName,
            Email = temoignage.Email,
            Profession = temoignage.Profession,
            PhotoUrl = temoignage.PhotoUrl,
            Promotion = temoignage.Promotion
        };
        JS.InvokeVoidAsync("openModal", "editTemoignageModal");
    }

    private async Task HandleTemoignageEdit(TemoignageModel editedTemoignage)
    {
        if (isSubmittingEditTemoignage) return;
        isSubmittingEditTemoignage = true;

        try
        {
            var response = await Http.PutAsJsonAsync($"http://localhost:5175/api/temoignages/{editedTemoignage.Id}", editedTemoignage);

            if (response.IsSuccessStatusCode)
            {
                var updatedTemoignage = await response.Content.ReadFromJsonAsync<TemoignageModel>();
                if (updatedTemoignage != null && Temoignages != null)
                {
                    var index = Temoignages.FindIndex(t => t.Id == updatedTemoignage.Id);
                    if (index != -1)
                    {
                        Temoignages[index] = updatedTemoignage;
                        await JS.InvokeVoidAsync("closeModal", "editTemoignageModal");
                        await JS.InvokeVoidAsync("alert", "Témoignage modifié avec succès !");
                        StateHasChanged();
                    }
                }
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Erreur lors de la modification du témoignage.");
            Console.WriteLine($"Erreur: {ex.Message}");
        }
        finally
        {
            isSubmittingEditTemoignage = false;
        }
    }

    private async Task DeleteTemoignage(TemoignageModel temoignage)
    {
        var response = await Http.DeleteAsync($"http://localhost:5175/api/temoignages/{temoignage.Id}");
        if (response.IsSuccessStatusCode)
        {
            Temoignages?.Remove(temoignage);
            StateHasChanged();
        }
    }

    private async Task DeleteEmploi(Guid id)
    {
        var token = await AuthService.GetTokenAsync();
        if (string.IsNullOrEmpty(token))
            return;

        Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        var response = await Http.DeleteAsync($"http://localhost:5175/api/emplois/{id}");

        if (response.IsSuccessStatusCode)
        {
            Emplois?.RemoveAll(e => e.Id == id);
            StateHasChanged();
        }
    }
}
