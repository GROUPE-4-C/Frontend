@page "/register"
@layout MainLayout
@inject AuthService AuthService
@inject NavigationManager Navigation
@using AlumniConnect.Front.Models
@using AlumniConnect.Front.Services

<link href="css/auth.css" rel="stylesheet" />

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h2>Inscription</h2>
            <p>Rejoignez la communauté AlumniConnect</p>
        </div>

        <!-- Indicateur d'étapes -->
        <div class="step-indicator @(currentStep == 2 ? "step-2" : "")">
            <div class="step-item @(currentStep >= 1 ? "active" : "") @(currentStep > 1 ? "completed" : "")">
                <div class="step-number">
                    @if (currentStep > 1)
                    {
                        <span>✓</span>
                    }
                    else
                    {
                        <span>1</span>
                    }
                </div>
                <div class="step-label">Informations personnelles</div>
            </div>
            <div class="step-item @(currentStep >= 2 ? "active" : "")">
                <div class="step-number">2</div>
                <div class="step-label">Sécurité</div>
            </div>
        </div>

        <EditForm Model="registerModel" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            @if (errors.Any())
            {
                <div class="alert alert-danger">
                    @foreach (var error in errors)
                    {
                        <p>@error</p>
                    }
                </div>
            }

            @if (showSuccess)
            {
                <div class="alert alert-success">
                    <p>@successMessage</p>
                </div>
            }

            <!-- Étape 1: Informations personnelles -->
            <div class="step-content @(currentStep == 1 ? "active" : "")">
                <h3 class="step-title">Parlez-nous de vous</h3>
                <p class="step-subtitle">Ces informations nous aident à mieux vous connaître</p>

                <div class="form-group">
                    <label for="fullName">Nom complet *</label>
                    <InputText id="fullName" class="form-control" @bind-Value="registerModel.FullName" placeholder="Votre nom complet" />
                    <ValidationMessage For="@(() => registerModel.FullName)" />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="email">Email *</label>
                        <InputText id="email" type="email" class="form-control" @bind-Value="registerModel.Email" placeholder="votre@email.com" />
                        <ValidationMessage For="@(() => registerModel.Email)" />
                    </div>
                    <div class="form-group">
                        <label for="phoneNumber">Téléphone</label>
                        <InputText id="phoneNumber" type="tel" class="form-control" @bind-Value="registerModel.PhoneNumber" placeholder="+228 XX XX XX XX" />
                        <ValidationMessage For="@(() => registerModel.PhoneNumber)" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="profession">Profession *</label>
                        <InputText id="profession" class="form-control" @bind-Value="registerModel.Profession" placeholder="Votre profession" />
                        <ValidationMessage For="@(() => registerModel.Profession)" />
                    </div>
                    <div class="form-group">
                        <label for="promotionId">Promotion *</label>
                        <InputSelect id="promotionId" class="form-control" @bind-Value="registerModel.PromotionId">
                            <option value="0">Sélectionnez votre promotion</option>
                            <option value="1">Promotion 2020</option>
                            <option value="2">Promotion 2021</option>
                            <option value="3">Promotion 2022</option>
                            <option value="4">Promotion 2023</option>
                            <option value="5">Promotion 2024</option>
                        </InputSelect>
                        <ValidationMessage For="@(() => registerModel.PromotionId)" />
                    </div>
                </div>

                <div class="form-group">
                    <label for="bio">Bio (optionnel)</label>
                    <InputTextArea id="bio" class="form-control" @bind-Value="registerModel.Bio" placeholder="Parlez-nous de vous..." rows="3" />
                    <ValidationMessage For="@(() => registerModel.Bio)" />
                </div>

                <div class="form-group">
                    <label for="photo">Photo de profil (optionnel)</label>
                    <div class="photo-upload-section">
                        @if (!string.IsNullOrEmpty(photoPreview))
                        {
                            <div class="photo-preview">
                                <img src="@photoPreview" alt="Aperçu photo" />
                                <button type="button" class="remove-photo-btn" @onclick="RemovePhoto">
                                    ✕
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="photo-placeholder">
                                <i class="fas fa-camera"></i>
                            </div>
                        }
                        <InputFile id="photo" class="form-control file-input" OnChange="OnPhotoSelected" accept="image/*" />
                        <small class="form-text">Formats acceptés : JPG, PNG, GIF (max 5MB)</small>
                    </div>
                </div>

                <div class="step-buttons">
                    <button type="button" class="btn btn-primary btn-full" @onclick="NextStep">
                        Suivant
                    </button>
                </div>
            </div>

            <!-- Étape 2: Sécurité -->
            <div class="step-content @(currentStep == 2 ? "active" : "")">
                <h3 class="step-title">Sécurisez votre compte</h3>
                <p class="step-subtitle">Choisissez un mot de passe fort pour protéger votre compte</p>

                <div class="form-group">
                    <label for="password">Mot de passe *</label>
                    <InputText id="password" type="password" class="form-control" @bind-Value="registerModel.Password" placeholder="Votre mot de passe" />
                    <ValidationMessage For="@(() => registerModel.Password)" />
                    <small class="form-text">Au moins 6 caractères</small>
                </div>

                <div class="form-group">
                    <label for="confirmPassword">Confirmer le mot de passe *</label>
                    <InputText id="confirmPassword" type="password" class="form-control" @bind-Value="registerModel.ConfirmPassword" placeholder="Confirmez votre mot de passe" />
                    <ValidationMessage For="@(() => registerModel.ConfirmPassword)" />
                </div>

                <div class="step-buttons">
                    <button type="button" class="btn btn-secondary btn-half" @onclick="PreviousStep">
                        Précédent
                    </button>
                    <button type="submit" class="btn btn-primary btn-half" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner"></span>
                            <span>Inscription...</span>
                        }
                        else
                        {
                            <span>S'inscrire</span>
                        }
                    </button>
                </div>
            </div>
        </EditForm>

        <div class="auth-footer">
            <p>Déjà membre ? <a href="/login">Se connecter</a></p>
        </div>
    </div>
</div>

@code {
    private RegisterDto registerModel = new();
    private List<string> errors = new();
    private bool isLoading = false;
    private bool showSuccess = false;
    private string successMessage = string.Empty;
    private string? photoPreview;
    private int currentStep = 1;

    protected override async Task OnInitializedAsync()
    {
        // Vérifier si l'utilisateur est déjà connecté
        if (await AuthService.IsAuthenticatedAsync())
        {
            Navigation.NavigateTo("/dashboard");
        }
    }

    private void NextStep()
    {
        errors.Clear();

        // Validation de l'étape 1
        if (!ValidateStep1())
        {
            return;
        }

        currentStep = 2;
        StateHasChanged();
    }

    private void PreviousStep()
    {
        errors.Clear();
        currentStep = 1;
        StateHasChanged();
    }

    private bool ValidateStep1()
    {
        var stepErrors = new List<string>();

        if (string.IsNullOrWhiteSpace(registerModel.FullName))
            stepErrors.Add("Le nom complet est requis.");

        if (string.IsNullOrWhiteSpace(registerModel.Email))
            stepErrors.Add("L'email est requis.");
        else if (!IsValidEmail(registerModel.Email))
            stepErrors.Add("Format d'email invalide.");

        if (string.IsNullOrWhiteSpace(registerModel.Profession))
            stepErrors.Add("La profession est requise.");

        if (registerModel.PromotionId == 0)
            stepErrors.Add("Veuillez sélectionner une promotion.");

        if (!string.IsNullOrEmpty(registerModel.PhoneNumber) && !IsValidPhone(registerModel.PhoneNumber))
            stepErrors.Add("Format de téléphone invalide.");

        if (stepErrors.Any())
        {
            errors.AddRange(stepErrors);
            return false;
        }

        return true;
    }

    private bool IsValidEmail(string email)
    {
        try
        {
            var addr = new System.Net.Mail.MailAddress(email);
            return addr.Address == email;
        }
        catch
        {
            return false;
        }
    }

    private bool IsValidPhone(string phone)
    {
        return phone.All(c => char.IsDigit(c) || c == '+' || c == ' ' || c == '-' || c == '(' || c == ')');
    }

    private async Task HandleSubmit()
    {
        if (currentStep == 1)
        {
            NextStep();
            return;
        }

        await HandleRegister();
    }

    private async Task OnPhotoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            // Nettoyer les erreurs précédentes liées aux photos
            errors.RemoveAll(error => error.Contains("photo") || error.Contains("image") || error.Contains("fichier"));

            // Validation taille
            if (file.Size > 5 * 1024 * 1024)
            {
                errors.Add("La photo ne doit pas dépasser 5MB.");
                StateHasChanged();
                return;
            }

            // Validation type
            if (!file.ContentType.StartsWith("image/"))
            {
                errors.Add("Seuls les fichiers image sont acceptés.");
                StateHasChanged();
                return;
            }

            try
            {
                // Lire le fichier
                using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
                using var memoryStream = new MemoryStream();
                await stream.CopyToAsync(memoryStream);

                var bytes = memoryStream.ToArray();

                // Créer le base64 pour l'aperçu
                photoPreview = $"data:{file.ContentType};base64,{Convert.ToBase64String(bytes)}";

                // Stocker pour l'API (avec le préfixe data: pour que le backend puisse l'identifier)
                registerModel.PhotoBase64 = photoPreview;

                StateHasChanged();
            }
            catch (Exception ex)
            {
                errors.Add($"Erreur lors du chargement de la photo: {ex.Message}");
                StateHasChanged();
            }
        }
    }

    private void RemovePhoto()
    {
        photoPreview = null;
        registerModel.PhotoBase64 = null;

        // Nettoyer les erreurs liées aux photos
        errors.RemoveAll(error => error.Contains("photo") || error.Contains("image") || error.Contains("fichier"));

        StateHasChanged();
    }

    private async Task HandleRegister()
    {
        isLoading = true;
        errors.Clear();
        showSuccess = false;

        try
        {
            // Validation finale côté client
            if (registerModel.Password != registerModel.ConfirmPassword)
            {
                errors.Add("Les mots de passe ne correspondent pas.");
                return;
            }

            if (string.IsNullOrWhiteSpace(registerModel.Password) || registerModel.Password.Length < 6)
            {
                errors.Add("Le mot de passe doit contenir au moins 6 caractères.");
                return;
            }

            // Appel à l'API
            var result = await AuthService.RegisterAsync(registerModel);

            if (result.Success)
            {
                successMessage = result.Message;
                showSuccess = true;

                // Petite pause pour montrer le succès
                await Task.Delay(2000);

                // Redirection vers la page de confirmation avec l'email
                Navigation.NavigateTo($"/confirm-email?email={Uri.EscapeDataString(registerModel.Email)}");
            }
            else
            {
                // Gérer les erreurs de l'API
                if (result.Errors != null && result.Errors.Any())
                {
                    errors.AddRange(result.Errors);
                }
                else if (!string.IsNullOrEmpty(result.Message))
                {
                    errors.Add(result.Message);
                }
                else
                {
                    errors.Add("Erreur lors de l'inscription. Veuillez réessayer.");
                }
            }
        }
        catch (Exception ex)
        {
            errors.Add($"Erreur inattendue: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
}
