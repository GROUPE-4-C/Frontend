@page "/confirm-email"
@layout MainLayout
@inject AuthService AuthService
@inject NavigationManager Navigation
@using AlumniConnect.Front.Models
@using AlumniConnect.Front.Services

<link href="css/auth.css" rel="stylesheet" />

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h2>Confirmation d'email</h2>
            <p>Entrez le code de vérification envoyé à votre email</p>
            @if (!string.IsNullOrEmpty(Email))
            {
                <p><strong>@Email</strong></p>
            }
        </div>

        <EditForm Model="confirmModel" OnValidSubmit="HandleConfirmEmail">
            <DataAnnotationsValidator />

            @if (errors.Any())
            {
                <div class="alert alert-danger">
                    @foreach (var error in errors)
                    {
                        <p>@error</p>
                    }
                </div>
            }

            @if (showSuccess)
            {
                <div class="alert alert-success">
                    <p>@successMessage</p>
                </div>
            }

            <div class="form-group">
                <label for="email">Email</label>
                <InputText id="email" type="email" class="form-control" @bind-Value="confirmModel.Email" placeholder="votre@email.com" />
                <ValidationMessage For="@(() => confirmModel.Email)" />
            </div>

            <div class="form-group">
                <label for="token">Code de vérification</label>
                <InputText id="token" class="form-control otp-input" @bind-Value="confirmModel.Token" placeholder="123456" maxlength="6" />
                <ValidationMessage For="@(() => confirmModel.Token)" />
                <small class="form-text">Code à 6 chiffres envoyé par email</small>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary btn-full" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner"></span>
                        <span>Vérification en cours...</span>
                    }
                    else
                    {
                        <span>Confirmer</span>
                    }
                </button>
            </div>
        </EditForm>

        <div class="auth-links">
            <button type="button" class="link-button" @onclick="HandleResendOtp" disabled="@isResending">
                @if (isResending)
                {
                    <span class="spinner-small"></span>
                    <span>Envoi en cours...</span>
                }
                else
                {
                    <span>Renvoyer le code</span>
                }
            </button>
        </div>

        <div class="auth-footer">
            <p>Code reçu ? <a href="/login">Se connecter</a></p>
        </div>
    </div>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? Email { get; set; }

    private ConfirmEmailDto confirmModel = new();
    private List<string> errors = new();
    private bool isLoading = false;
    private bool isResending = false;
    private bool showSuccess = false;
    private string successMessage = string.Empty;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(Email))
        {
            confirmModel.Email = Email;
        }
    }

    private async Task HandleConfirmEmail()
    {
        isLoading = true;
        errors.Clear();
        showSuccess = false;

        try
        {
            var result = await AuthService.ConfirmEmailAsync(confirmModel);

            if (result.Success)
            {
                successMessage = result.Message;
                showSuccess = true;

                // Attendre un peu pour montrer le message de succès
                await Task.Delay(2000);

                // Redirection vers la page de connexion
                Navigation.NavigateTo("/login");
            }
            else
            {
                // Gérer les erreurs
                if (result.Errors != null && result.Errors.Any())
                {
                    errors.AddRange(result.Errors);
                }
                else if (!string.IsNullOrEmpty(result.Message))
                {
                    errors.Add(result.Message);
                }
                else
                {
                    errors.Add("Erreur lors de la confirmation");
                }
            }
        }
        catch (Exception ex)
        {
            errors.Add($"Erreur inattendue: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleResendOtp()
    {
        if (string.IsNullOrEmpty(confirmModel.Email))
        {
            errors.Add("Veuillez saisir votre email.");
            return;
        }

        isResending = true;
        errors.Clear();

        try
        {
            var resendDto = new ResendOtpDto { Email = confirmModel.Email };
            var result = await AuthService.ResendOtpAsync(resendDto);

            if (result.Success)
            {
                successMessage = result.Message;
                showSuccess = true;
            }
            else
            {
                // Gérer les erreurs
                if (result.Errors != null && result.Errors.Any())
                {
                    errors.AddRange(result.Errors);
                }
                else if (!string.IsNullOrEmpty(result.Message))
                {
                    errors.Add(result.Message);
                }
                else
                {
                    errors.Add("Erreur lors du renvoi du code");
                }
            }
        }
        catch (Exception ex)
        {
            errors.Add($"Erreur inattendue: {ex.Message}");
        }
        finally
        {
            isResending = false;
        }
    }
}
