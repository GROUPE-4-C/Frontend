@page "/login"
@layout MainLayout
@inject AuthService AuthService
@inject NavigationManager Navigation
@using AlumniConnect.Front.Models
@using AlumniConnect.Front.Services

<link href="css/auth.css" rel="stylesheet" />

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h2>Connexion</h2>
            <p>Connectez-vous à votre compte AlumniConnect</p>
        </div>

        <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            @if (errors.Any())
            {
                <div class="alert alert-danger">
                    @foreach (var error in errors)
                    {
                        <p>@error</p>
                    }
                </div>
            }

            @if (showSuccess)
            {
                <div class="alert alert-success">
                    <p>@successMessage</p>
                </div>
            }

            <div class="form-group">
                <label for="email">Email</label>
                <InputText id="email" type="email" class="form-control" @bind-Value="loginModel.Email" placeholder="votre@email.com" />
                <ValidationMessage For="@(() => loginModel.Email)" />
            </div>

            <div class="form-group">
                <label for="password">Mot de passe</label>
                <InputText id="password" type="password" class="form-control" @bind-Value="loginModel.Password" placeholder="Votre mot de passe" />
                <ValidationMessage For="@(() => loginModel.Password)" />
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary btn-full" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner"></span>
                        <span>Connexion en cours...</span>
                    }
                    else
                    {
                        <span>Se connecter</span>
                    }
                </button>
            </div>
        </EditForm>

        <div class="auth-links">
            <a href="/forgot-password">Mot de passe oublié ?</a>
        </div>

        <div class="auth-footer">
            <p>Pas encore membre ? <a href="/register">S'inscrire</a></p>
        </div>
    </div>
</div>

@code {
    private LoginDto loginModel = new();
    private List<string> errors = new();
    private bool isLoading = false;
    private bool showSuccess = false;
    private string successMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        // Vérifier si l'utilisateur est déjà connecté
        if (await AuthService.IsAuthenticatedAsync())
        {
            Navigation.NavigateTo("/dashboard");
        }
    }

    private async Task HandleLogin()
    {
        isLoading = true;
        errors.Clear();
        showSuccess = false;

        try
        {
            var result = await AuthService.LoginAsync(loginModel);

            if (result.Success && result.Data != null)
            {
                successMessage = result.Message;
                showSuccess = true;

                // Attendre un peu pour montrer le message de succès
                await Task.Delay(1000);

                // Redirection vers dashboard
                Navigation.NavigateTo("/dashboard");
            }
            else
            {
                // Gérer les erreurs
                if (result.Errors != null && result.Errors.Any())
                {
                    errors.AddRange(result.Errors);
                }
                else if (!string.IsNullOrEmpty(result.Message))
                {
                    errors.Add(result.Message);
                }
                else
                {
                    errors.Add("Erreur lors de la connexion");
                }
            }
        }
        catch (Exception ex)
        {
            errors.Add($"Erreur inattendue: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
}
