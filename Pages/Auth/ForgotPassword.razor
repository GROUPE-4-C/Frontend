@page "/forgot-password"
@layout MainLayout
@inject AuthService AuthService
@inject NavigationManager Navigation
@using AlumniConnect.Front.Models
@using AlumniConnect.Front.Services

<link href="css/auth.css" rel="stylesheet" />

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h2>Mot de passe oublié</h2>
            <p>Entrez votre email pour recevoir un code de réinitialisation</p>
        </div>

        <EditForm Model="forgotPasswordModel" OnValidSubmit="HandleForgotPassword">
            <DataAnnotationsValidator />

            @if (errors.Any())
            {
                <div class="alert alert-danger">
                    @foreach (var error in errors)
                    {
                        <p>@error</p>
                    }
                </div>
            }

            @if (showSuccess)
            {
                <div class="alert alert-success">
                    <p>@successMessage</p>
                </div>
            }

            <div class="form-group">
                <label for="email">Email</label>
                <InputText id="email" type="email" class="form-control" @bind-Value="forgotPasswordModel.Email" placeholder="votre@email.com" />
                <ValidationMessage For="@(() => forgotPasswordModel.Email)" />
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary btn-full" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner"></span>
                        <span>Envoi en cours...</span>
                    }
                    else
                    {
                        <span>Envoyer le code</span>
                    }
                </button>
            </div>
        </EditForm>

        <div class="auth-footer">
            <p>Vous vous souvenez de votre mot de passe ? <a href="/login">Se connecter</a></p>
        </div>
    </div>
</div>

@code {
    private ResendOtpDto forgotPasswordModel = new();
    private List<string> errors = new();
    private bool isLoading = false;
    private bool showSuccess = false;
    private string successMessage = string.Empty;

    private async Task HandleForgotPassword()
    {
        isLoading = true;
        errors.Clear();
        showSuccess = false;

        try
        {
            var result = await AuthService.RequestResetPasswordOtpAsync(forgotPasswordModel);

            if (result.Success)
            {
                successMessage = result.Message;
                showSuccess = true;

                // Attendre un peu pour montrer le message de succès
                await Task.Delay(2000);

                // Redirection vers la page de réinitialisation avec l'email
                Navigation.NavigateTo($"/reset-password?email={Uri.EscapeDataString(forgotPasswordModel.Email)}");
            }
            else
            {
                // Gérer les erreurs
                if (result.Errors != null && result.Errors.Any())
                {
                    errors.AddRange(result.Errors);
                }
                else if (!string.IsNullOrEmpty(result.Message))
                {
                    errors.Add(result.Message);
                }
                else
                {
                    errors.Add("Erreur lors de l'envoi du code");
                }
            }
        }
        catch (Exception ex)
        {
            errors.Add($"Erreur inattendue: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
}
