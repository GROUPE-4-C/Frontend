@page "/forgot-password"
@layout MainLayout

<link href="css/auth.css" rel="stylesheet" />

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h2>Mot de passe oublié</h2>
            <p>Entrez votre email pour recevoir un code de réinitialisation</p>
        </div>

        <EditForm Model="forgotPasswordModel" OnValidSubmit="HandleForgotPassword">
            <DataAnnotationsValidator />

            @if (errors.Any())
            {
                <div class="alert alert-danger">
                    @foreach (var error in errors)
                    {
                        <p>@error</p>
                    }
                </div>
            }

            @if (showSuccess)
            {
                <div class="alert alert-success">
                    <p>Code de réinitialisation envoyé ! Vérifiez votre email.</p>
                </div>
            }

            <div class="form-group">
                <label for="email">Email</label>
                <InputText id="email" type="email" class="form-control" @bind-Value="forgotPasswordModel.Email" placeholder="votre@email.com" />
                <ValidationMessage For="@(() => forgotPasswordModel.Email)" />
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary btn-full" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner"></span>
                        <span>Envoi en cours...</span>
                    }
                    else
                    {
                        <span>Envoyer le code</span>
                    }
                </button>
            </div>
        </EditForm>

        <div class="auth-footer">
            <p>Vous vous souvenez de votre mot de passe ? <a href="/login">Se connecter</a></p>
        </div>
    </div>
</div>

@inject NavigationManager Navigation
@using System.ComponentModel.DataAnnotations

@code {
    private ForgotPasswordModel forgotPasswordModel = new();
    private List<string> errors = new();
    private bool isLoading = false;
    private bool showSuccess = false;

    private async Task HandleForgotPassword()
    {
        isLoading = true;
        errors.Clear();
        showSuccess = false;

        try
        {
            await Task.Delay(2000);
            showSuccess = true;

            await Task.Delay(2000);
            Navigation.NavigateTo($"/reset-password?email={Uri.EscapeDataString(forgotPasswordModel.Email)}");
        }
        catch (Exception ex)
        {
            errors.Add($"Erreur lors de l'envoi: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    public class ForgotPasswordModel
    {
        [Required(ErrorMessage = "L'email est requis")]
        [EmailAddress(ErrorMessage = "Format d'email invalide")]
        public string Email { get; set; } = string.Empty;
    }
}
