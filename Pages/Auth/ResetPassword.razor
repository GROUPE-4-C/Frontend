@page "/reset-password"
@layout MainLayout
@inject AuthService AuthService
@inject NavigationManager Navigation
@using AlumniConnect.Front.Models
@using AlumniConnect.Front.Services

<link href="css/auth.css" rel="stylesheet" />

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h2>Réinitialiser le mot de passe</h2>
            <p>Entrez le code reçu par email et votre nouveau mot de passe</p>
            @if (!string.IsNullOrEmpty(Email))
            {
                <p><strong>@Email</strong></p>
            }
        </div>

        <EditForm Model="resetPasswordModel" OnValidSubmit="HandleResetPassword">
            <DataAnnotationsValidator />

            @if (errors.Any())
            {
                <div class="alert alert-danger">
                    @foreach (var error in errors)
                    {
                        <p>@error</p>
                    }
                </div>
            }

            @if (showSuccess)
            {
                <div class="alert alert-success">
                    <p>@successMessage</p>
                </div>
            }

            <div class="form-group">
                <label for="email">Email</label>
                <InputText id="email" type="email" class="form-control" @bind-Value="resetPasswordModel.Email" placeholder="votre@email.com" />
                <ValidationMessage For="@(() => resetPasswordModel.Email)" />
            </div>

            <div class="form-group">
                <label for="otp">Code de vérification</label>
                <InputText id="otp" class="form-control otp-input" @bind-Value="resetPasswordModel.Otp" placeholder="123456" maxlength="6" />
                <ValidationMessage For="@(() => resetPasswordModel.Otp)" />
                <small class="form-text">Code à 6 chiffres envoyé par email</small>
            </div>

            <div class="form-group">
                <label for="newPassword">Nouveau mot de passe</label>
                <InputText id="newPassword" type="password" class="form-control" @bind-Value="resetPasswordModel.NewPassword" placeholder="Nouveau mot de passe" />
                <ValidationMessage For="@(() => resetPasswordModel.NewPassword)" />
            </div>

            <div class="form-group">
                <label for="confirmPassword">Confirmer le mot de passe</label>
                <InputText id="confirmPassword" type="password" class="form-control" @bind-Value="confirmPassword" placeholder="Confirmez le mot de passe" />
                <ValidationMessage For="@(() => confirmPassword)" />
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary btn-full" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner"></span>
                        <span>Réinitialisation en cours...</span>
                    }
                    else
                    {
                        <span>Réinitialiser</span>
                    }
                </button>
            </div>
        </EditForm>

        <div class="auth-footer">
            <p>Mot de passe changé ? <a href="/login">Se connecter</a></p>
        </div>
    </div>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? Email { get; set; }

    private ResetPasswordDto resetPasswordModel = new();
    private string confirmPassword = string.Empty;
    private List<string> errors = new();
    private bool isLoading = false;
    private bool showSuccess = false;
    private string successMessage = string.Empty;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(Email))
        {
            resetPasswordModel.Email = Email;
        }
    }

    private async Task HandleResetPassword()
    {
        isLoading = true;
        errors.Clear();
        showSuccess = false;

        try
        {
            // Validation côté client
            if (resetPasswordModel.NewPassword != confirmPassword)
            {
                errors.Add("Les mots de passe ne correspondent pas.");
                return;
            }

            if (string.IsNullOrWhiteSpace(resetPasswordModel.NewPassword) || resetPasswordModel.NewPassword.Length < 6)
            {
                errors.Add("Le mot de passe doit contenir au moins 6 caractères.");
                return;
            }

            var result = await AuthService.ResetPasswordAsync(resetPasswordModel);

            if (result.Success)
            {
                successMessage = result.Message;
                showSuccess = true;

                // Attendre un peu pour montrer le message de succès
                await Task.Delay(2000);

                // Redirection vers la page de connexion
                Navigation.NavigateTo("/login");
            }
            else
            {
                // Gérer les erreurs
                if (result.Errors != null && result.Errors.Any())
                {
                    errors.AddRange(result.Errors);
                }
                else if (!string.IsNullOrEmpty(result.Message))
                {
                    errors.Add(result.Message);
                }
                else
                {
                    errors.Add("Erreur lors de la réinitialisation");
                }
            }
        }
        catch (Exception ex)
        {
            errors.Add($"Erreur inattendue: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
}
